#!/usr/bin/env bash
# sable-test — run a test command and, ONLY on a green (exit 0) result, record
# TDD evidence at the shared evidence key (SABLE-jfg6.4 / contract D4).
#
# This is the evidence seam SABLE owns for session types that fire NO hooks
# (Agent-subagent / gc-managed; research F3, Claude Code #34692 WONTFIX). In
# those envs tdd-evidence.sh never fires, so a genuine green run leaves no
# evidence and tdd-gate.sh false-blocks the close. The worker runs its suite
# THROUGH this wrapper instead, so the evidence exists regardless. The key is
# derived by lib-evidence-key.sh — the SAME derivation tdd-gate.sh reads — so
# the writer and reader can never drift (the tfkv mismatch class).
#
# Contract:
#   * runs the given command verbatim, streaming its stdout/stderr through;
#   * propagates the command's EXACT exit code;
#   * writes the evidence file ONLY on exit 0. A red run writes NOTHING —
#     false-permissive (green evidence for a failed suite) is the catastrophic
#     failure mode, so the write is strictly gated on success.
#
# Usage:
#   sable-test <test-command> [args...]
#   sable-test bash hooks/test/test-foo.sh
#   sable-test pytest tests/ -x

set -uo pipefail

usage() {
  cat <<'EOF'
sable-test — run a test command; on a green (exit 0) result, record TDD
evidence at the shared evidence key so tdd-gate.sh allows the close.

Usage:
  sable-test <test-command> [args...]

A red run propagates the command's exit code and writes NO evidence.
EOF
}

if [ $# -lt 1 ]; then
  usage >&2
  exit 2
fi

case "$1" in
  -h|--help) usage; exit 0 ;;
esac

# Resolve this script's PHYSICAL dir (follow the symlink chain) so we source the
# repo's lib even when invoked through an installed ~/.local/bin symlink
# (sable-bin-install links it) — same pattern as sable-bin-install (SABLE-5p2).
SOURCE="${BASH_SOURCE[0]:-$0}"
while [ -h "$SOURCE" ]; do
  _dir="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  case "$SOURCE" in /*) ;; *) SOURCE="$_dir/$SOURCE" ;; esac
done
BIN_DIR="$(cd -P "$(dirname "$SOURCE")" >/dev/null 2>&1 && pwd)"
LIB="$BIN_DIR/../hooks/multi-manager/lib-evidence-key.sh"

if [ -r "$LIB" ]; then
  # shellcheck source=../hooks/multi-manager/lib-evidence-key.sh
  . "$LIB"
fi

# Run the test command, propagating its exit code (no `set -e`, so a red run is
# captured, not aborted, and its code flows to the final `exit`).
"$@"
rc=$?

if [ "$rc" -eq 0 ]; then
  if command -v sable_evidence_key >/dev/null 2>&1; then
    # SABLE-0w0ou: this used to read ONLY CLAUDE_SESSION_ID (empty in every
    # warm-pane worker session), so it silently fell to the lib's ppid
    # fallback while tdd-gate.sh's reader picked up the real, POPULATED
    # session id from the PreToolUse hook JSON — two different non-empty
    # keys, permanent false-deny on bd close. The in-file comment that used
    # to sit here declined to ever substitute CLAUDE_CODE_SESSION_ID "to
    # avoid a mismatch" — that premise is false and disproved empirically:
    # in a hooks-fire session the PreToolUse JSON's session_id IS
    # CLAUDE_CODE_SESSION_ID, byte-for-byte (the evidence file the hook
    # writes is literally named /tmp/tdd-evidence-<CLAUDE_CODE_SESSION_ID>).
    # sable_resolve_session_id() (owned by the shared lib, not re-derived
    # here) walks CLAUDE_SESSION_ID -> CLAUDE_CODE_SESSION_ID before giving
    # up to the ppid fallback, which stays reserved for the genuinely
    # no-identity-available case (no hook ever ran, neither var is set).
    SID=$(sable_resolve_session_id)
    AID="${CLAUDE_AGENT_ID:-}"
    EVIDENCE_FILE=$(sable_evidence_key "$SID" "$AID")
    REPO_TAG=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
    TS="$(date -Iseconds 2>/dev/null || date 2>/dev/null || echo '?')"
    printf '%s REPO=%s CMD=%s\n' "$TS" "$REPO_TAG" "$*" >> "$EVIDENCE_FILE" 2>/dev/null || true
  else
    printf 'sable-test: WARNING — lib-evidence-key.sh not found at %s; wrote NO evidence (close may be blocked)\n' "$LIB" >&2
  fi
fi

exit "$rc"
