#!/usr/bin/env python3
"""sable-view — inspect the SABLE agent panes mid-session (SABLE-ssws.3).

The warm-pane session hides most of its activity: managers work in their own
panes and workers open in separate WINDOWS behind the one you are looking at.
This is the peek tool:

  sable-view                     status table of every role pane + worker window
  sable-view <role>              focus that pane (switch/attach as appropriate)
  sable-view <role> --tail [-n N]  print the pane's last N lines, no focus change
  sable-view --json              machine-readable status

Roles come from the @sable_role pane option written by sable-tmux and the
worker-spawn helper; worker panes also carry @sable_bead / @sable_status.

Env: SABLE_TMUX_SESSION (default: sable), SABLE_TMUX_SOCKET (tmux -L).
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys

_FORMAT = "#{window_index} #{pane_id} #{@sable_role} #{@sable_bead} #{@sable_status}"
ACTIVITY_WIDTH = 60


def tmux_base(socket: str | None) -> list[str]:
    return ["tmux", "-L", socket] if socket else ["tmux"]


def parse_panes(output: str) -> list[dict]:
    """Parse `list-panes -s -F '<window> <pane> <role> <bead> <status>'` lines.
    Panes without a @sable_role are not SABLE agents and are skipped."""
    panes: list[dict] = []
    for line in output.splitlines():
        parts = line.split()
        if len(parts) < 3:
            continue
        window, pane, role = parts[0], parts[1], parts[2]
        panes.append({
            "window": window,
            "pane": pane,
            "role": role,
            "bead": parts[3] if len(parts) >= 4 else "",
            "status": parts[4] if len(parts) >= 5 else "",
        })
    return panes


def resolve_target(panes: list[dict], role: str) -> dict:
    """First pane whose role matches exactly. Raises ValueError naming the
    known roles when nothing matches."""
    for p in panes:
        if p["role"] == role:
            return p
    known = ", ".join(sorted({p["role"] for p in panes})) or "none"
    raise ValueError(f"unknown role '{role}' (known roles: {known})")


def last_line(capture: str) -> str:
    """Last non-empty line of a capture, truncated — the at-a-glance activity hint."""
    for line in reversed(capture.splitlines() or [capture]):
        s = line.strip()
        if s:
            return s[:ACTIVITY_WIDTH]
    return ""


def render_table(panes: list[dict], activity: dict[str, str]) -> str:
    rows = [f"{'ROLE':<10} {'PANE':<7} {'WIN':<4} {'BEAD':<16} {'STATUS':<8} ACTIVITY"]
    for p in panes:
        rows.append(f"{p['role']:<10} {p['pane']:<7} {p['window']:<4} "
                    f"{p['bead']:<16} {p['status']:<8} {activity.get(p['pane'], '')}")
    return "\n".join(rows)


def _run(args: list[str]) -> str:
    return subprocess.run(args, capture_output=True, text=True, check=True).stdout


def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(prog="sable-view")
    p.add_argument("role", nargs="?", help="focus this role's pane (or --tail it)")
    p.add_argument("--tail", action="store_true",
                   help="print the role's pane content instead of focusing it")
    p.add_argument("-n", type=int, default=40, help="lines for --tail (default 40)")
    p.add_argument("--no-attach", action="store_true",
                   help="focus form: select the pane server-side, don't attach/switch")
    p.add_argument("--json", action="store_true", help="machine-readable status")
    ns = p.parse_args(sys.argv[1:] if argv is None else argv)

    socket = os.environ.get("SABLE_TMUX_SOCKET") or None
    session = os.environ.get("SABLE_TMUX_SESSION") or "sable"
    base = tmux_base(socket)

    if subprocess.run(base + ["has-session", "-t", session],
                      capture_output=True).returncode != 0:
        sys.stderr.write(f"sable-view: no '{session}' session — start one with: sable-launch\n")
        return 1

    listing = _run(base + ["list-panes", "-s", "-t", session, "-F", _FORMAT])
    panes = parse_panes(listing)

    if ns.role is None:
        if ns.json:
            print(json.dumps(panes, indent=2))
            return 0
        activity = {}
        for pane in panes:
            cap = subprocess.run(base + ["capture-pane", "-p", "-t", pane["pane"]],
                                 capture_output=True, text=True).stdout
            activity[pane["pane"]] = last_line(cap)
        print(render_table(panes, activity))
        return 0

    try:
        target = resolve_target(panes, ns.role)
    except ValueError as e:
        sys.stderr.write(f"sable-view: {e}\n")
        return 2

    if ns.tail:
        cap = _run(base + ["capture-pane", "-p", "-t", target["pane"]])
        lines = cap.splitlines()
        print("\n".join(lines[-ns.n:]))
        return 0

    # Focus form: select server-side, then bring a client there.
    subprocess.run(base + ["select-window", "-t", f"{session}:{target['window']}"],
                   check=True)
    subprocess.run(base + ["select-pane", "-t", target["pane"]], check=True)
    if ns.no_attach:
        return 0
    if os.environ.get("TMUX"):
        cur = subprocess.run(base + ["display-message", "-p", "#S"],
                             capture_output=True, text=True).stdout.strip()
        if cur == session:
            return 0
        os.execvp("tmux", base + ["switch-client", "-t", session])
    os.execvp("tmux", base + ["attach", "-t", session])


if __name__ == "__main__":
    sys.exit(main())
