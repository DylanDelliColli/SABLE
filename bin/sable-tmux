#!/usr/bin/env python3
"""sable-tmux — lay out a SABLE warm-pane session (SABLE-bldh.2).

One command stands up the tmux session the operator drives: one warm `claude`
pane per role (lincoln, optimus, tarzan, chuck), each with its identity set
(CLAUDE_AGENT_NAME via tmux -e) and registered for the messaging/worker tools
(@sable_role pane user-option). Replaces opening N terminals by hand.

  lincoln  — the cockpit pane you talk to
  optimus  — epic manager      } resident managers; they spawn worker windows
  tarzan   — one-off manager   } via sable-spawn-worker
  chuck    — merge queue

Usage:
  sable-tmux [--session NAME] [--roles lincoln,optimus,tarzan,chuck] [--attach]

Env:
  SABLE_TMUX_SOCKET     tmux socket (-L) for isolation/tests
  SABLE_TMUX_PANE_CMD   per-pane command (default: 'claude'); override for tests

After it runs, attach with:  tmux attach -t <session>
"""
from __future__ import annotations

import argparse
import os
import subprocess
import sys

DEFAULT_ROLES = ["lincoln", "optimus", "tarzan", "chuck"]


def parse_roles(arg: str | None) -> list[str]:
    if not arg:
        return list(DEFAULT_ROLES)
    return [r.strip() for r in arg.split(",") if r.strip()]


def pane_env_args(role: str) -> list[str]:
    return ["-e", f"CLAUDE_AGENT_NAME={role}", "-e", "CLAUDE_AGENT_ROLE=manager"]


def pane_command() -> str:
    return os.environ.get("SABLE_TMUX_PANE_CMD") or "claude"


def tmux_base(socket: str | None) -> list[str]:
    return ["tmux", "-L", socket] if socket else ["tmux"]


def _run(args: list[str]) -> str:
    return subprocess.run(args, capture_output=True, text=True, check=True).stdout


def _tag(base, pane, role):
    subprocess.run(base + ["set-option", "-p", "-t", pane, "@sable_role", role], check=True)


def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(prog="sable-tmux")
    p.add_argument("--session", default=os.environ.get("SABLE_TMUX_SESSION") or "sable")
    p.add_argument("--roles", help="comma-separated role list (default: all four)")
    p.add_argument("--attach", action="store_true", help="attach after layout")
    ns = p.parse_args(sys.argv[1:] if argv is None else argv)

    roles = parse_roles(ns.roles)
    if not roles:
        sys.stderr.write("sable-tmux: no roles\n")
        return 2
    socket = os.environ.get("SABLE_TMUX_SOCKET") or None
    base = tmux_base(socket)
    sess = ns.session
    cmd = pane_command()

    # refuse to clobber an existing session
    if subprocess.run(base + ["has-session", "-t", sess],
                      capture_output=True).returncode == 0:
        sys.stderr.write(f"sable-tmux: session '{sess}' already exists "
                         f"(attach with: tmux attach -t {sess})\n")
        return 1

    # first role -> new session; rest -> tiled splits
    first = roles[0]
    pane = _run(base + ["new-session", "-d", "-s", sess, "-x", "220", "-y", "55",
                        "-P", "-F", "#{pane_id}", *pane_env_args(first), cmd]).strip()
    _tag(base, pane, first)
    for role in roles[1:]:
        pane = _run(base + ["split-window", "-t", sess, "-P", "-F", "#{pane_id}",
                            *pane_env_args(role), cmd]).strip()
        _tag(base, pane, role)
        subprocess.run(base + ["select-layout", "-t", sess, "tiled"], check=True)

    sys.stderr.write(f"sable-tmux: session '{sess}' up with roles: {', '.join(roles)}\n")
    sys.stderr.write(f"  attach: tmux{' -L ' + socket if socket else ''} attach -t {sess}\n")
    if ns.attach:
        os.execvp("tmux", base[0:1] + base[1:] + ["attach", "-t", sess])
    return 0


if __name__ == "__main__":
    sys.exit(main())
