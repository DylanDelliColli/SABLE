#!/usr/bin/env python3
"""sable-worker-status — list SABLE worker panes and (optionally) reap done ones.

Part of the warm-pane worker lifecycle (SABLE-bldh.4). A worker pane carries
three tmux per-pane user-options:
  @sable_role=worker     set by sable-spawn-worker at spawn
  @sable_bead=<id>       the bead the worker is executing
  @sable_status=running  flipped to "done" by the worker as its final act
                         (after it pushes its worktree branch + closes its bead)

The bead pool is the manager's RESULT channel (the manager reviews the closed
bead). This tool is the janitor: it surfaces worker liveness and reaps panes
whose worker has flagged itself done — pure tmux, no bd coupling.

Usage:
  sable-worker-status            # table of worker panes (pane / bead / status)
  sable-worker-status --reap     # also kill panes whose @sable_status=done
  sable-worker-status --json

Env:
  SABLE_TMUX_SOCKET   tmux socket name (-L); for session isolation / tests
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys

WORKER_ROLE_PREFIX = "worker"
_FORMAT = "#{pane_id} #{@sable_role} #{@sable_bead} #{@sable_status}"


def tmux_base(socket: str | None) -> list[str]:
    return ["tmux", "-L", socket] if socket else ["tmux"]


def parse_worker_panes(output: str) -> list[dict]:
    """Parse `tmux list-panes -F '<pane> <role> <bead> <status>'` into worker
    records. Non-worker / role-less panes are skipped. Missing status defaults to
    'running' (a just-spawned worker may not have set it yet)."""
    workers: list[dict] = []
    for line in output.splitlines():
        parts = line.split()
        if len(parts) < 2:
            continue
        pane, role = parts[0], parts[1]
        if not role.startswith(WORKER_ROLE_PREFIX):
            continue
        bead = parts[2] if len(parts) >= 3 else ""
        status = parts[3] if len(parts) >= 4 and parts[3] else "running"
        workers.append({"pane": pane, "bead": bead, "status": status})
    return workers


def is_done(status: str) -> bool:
    return status == "done"


def reaping_decision(workers: list[dict]) -> list[str]:
    return [w["pane"] for w in workers if is_done(w["status"])]


def dedupe_panes(workers: list[dict]) -> list[dict]:
    """A grouped-session topology (`tmux new-session -t <sess> -s <alias>`
    shares one window list under two session names) makes `tmux list-panes -a`
    enumerate the SAME physical pane once per session alias. Collapse to one
    record per pane id, keeping the first occurrence, before anything reaps."""
    seen: set[str] = set()
    deduped: list[dict] = []
    for w in workers:
        if w["pane"] in seen:
            continue
        seen.add(w["pane"])
        deduped.append(w)
    return deduped


def _runner(args: list[str]) -> str:
    return subprocess.run(args, capture_output=True, text=True, check=True).stdout


def _capture_pane(base: list[str], pane: str) -> str:
    return subprocess.run(base + ["capture-pane", "-p", "-t", pane],
                          capture_output=True, text=True).stdout


def has_pending_input(capture: str) -> bool:
    """True if the pane's input box currently holds unsubmitted text — the
    composer line (prefixed by the tmux-native `>` or claude's `❯` prompt
    glyph) has content beyond the glyph itself. A done worker pane must never
    be silently killed while this is true (market-brief-package-0h8k): the
    text may be a misrouted/queued instruction nobody in the lane sent, and
    destroying the pane destroys the only evidence of it."""
    box = None
    for line in capture.splitlines():
        s = line.strip()
        if s.startswith("❯") or s.startswith(">"):
            box = s
    if box is None:
        return False
    return box not in ("❯", ">")


def list_workers(socket: str | None, run=_runner) -> list[dict]:
    out = run(tmux_base(socket) + ["list-panes", "-a", "-F", _FORMAT])
    return dedupe_panes(parse_worker_panes(out))


def reap(panes: list[str], socket: str | None, run=_runner, capture=None) -> list[str]:
    """Kill each done pane. One holding unsubmitted composer input is NOT
    silently killed over: clear it first (so no pane ever survives reap still
    holding pending input) and flag it loudly, then proceed with the kill —
    the worker is done regardless, but the anomaly must be visible to a human
    or manager, not swallowed. Returns the pane ids that were flagged."""
    base = tmux_base(socket)
    cap = capture or (lambda pane: _capture_pane(base, pane))
    flagged: list[str] = []
    for pane in panes:
        if has_pending_input(cap(pane)):
            flagged.append(pane)
            sys.stderr.write(
                f"sable-worker-status: pane {pane} is done but holds unsubmitted "
                f"composer input — clearing + flagging before reap "
                f"(market-brief-package-0h8k)\n")
            run(base + ["send-keys", "-t", pane, "C-u"])
        try:
            run(base + ["kill-pane", "-t", pane])
        except subprocess.CalledProcessError:
            # Already dead (e.g. a race between listing and this sweep, or a
            # concurrent reaper) — not a reason to abort the rest of the sweep.
            continue
    return flagged


def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(prog="sable-worker-status")
    p.add_argument("--reap", action="store_true",
                   help="kill panes whose @sable_status=done")
    p.add_argument("--json", action="store_true", help="machine-readable output")
    ns = p.parse_args(sys.argv[1:] if argv is None else argv)
    socket = os.environ.get("SABLE_TMUX_SOCKET") or None

    workers = list_workers(socket)

    if ns.json:
        print(json.dumps(workers, indent=2))
    else:
        if not workers:
            print("no worker panes")
        for w in workers:
            print(f"{w['pane']:<8} {w['bead']:<16} {w['status']}")

    if ns.reap:
        doomed = reaping_decision(workers)
        flagged = reap(doomed, socket)
        note = f", {len(flagged)} had pending input cleared+flagged" if flagged else ""
        sys.stderr.write(f"sable-worker-status: reaped {len(doomed)} done pane(s){note}\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
