#!/usr/bin/env python3
"""sable-worker-status — list SABLE worker/producer panes and (optionally)
reap done ones.

Part of the warm-pane lifecycle (SABLE-bldh.4, extended by SABLE-tz7h.2 for
bounded producer panes like victor). A dispatched pane carries tmux per-pane
user-options:
  @sable_class=worker|producer|manager   pane lifecycle classification
                                         (architecture.json decision 2)
  @sable_role=<role>     e.g. worker, victor, optimus
  @sable_bead=<id>       the bead the worker/producer is executing
  @sable_status=running  flipped to "done" by the pane as its final act
  @sable_deliverable=<path>  producer only: the JSON file it must write

Classification is driven by @sable_class: worker/producer panes are tracked;
manager panes (the always-on Optimus/Tarzan/Chuck loops) are never surfaced
or reaped. A pane with an EMPTY/missing @sable_class falls back to the legacy
WORKER_ROLE_PREFIX role-name check — back-compat for worker panes spawned by
sable-spawn-worker, which does not yet stamp @sable_class. A pane whose class
is some other, unrecognized value is still listed (so a human notices it) but
is never reap-eligible — a fail-safe for a tag this tool doesn't understand.

A done producer whose @sable_deliverable is missing or not valid JSON is NOT
killed; it is flagged "done-no-deliverable" in the report instead (the
SABLE-e6m6 pull-authoritative detection surface — the resume/respawn ACTION
stays with Lincoln in v1).

A "running" pane whose turn was cut off by the Claude Code session-rate-limit
banner ("hit your session limit ... resets ...") reads identically to a busy
pane by tag alone — an alive pane, status=running — and can sit stalled
indefinitely with nobody noticing (SABLE-ita7). Every running pane is
capture-paned each pass; one showing the banner AND an idle composer is
reported as "stalled-rate-limit" with the reset time attached, instead of
"running". Detection surface only in v1 — never reaped, never auto-nudged.

The bead pool is the manager's RESULT channel (the manager reviews the closed
bead). This tool is the janitor: it surfaces pane liveness and reaps panes
whose occupant has flagged itself done — pure tmux, no bd coupling.

By default the listing is scoped to the CALLER'S OWN lane — the panes stamped
@sable_lane == $CLAUDE_AGENT_NAME (SABLE-dcw2). Without this scoping any
manager's sweep saw — and --reap KILLED — every manager's worker panes: a
stranded-recovery sweep adopted another lane's just-spawned workers as orphans,
and a reap consumed DONE panes the owning manager was still event-waiting on.
--all restores the fleet-wide view; --lane <name> targets a specific lane. A
caller with no $CLAUDE_AGENT_NAME (e.g. the operator running it by hand) is
un-laned, so the default is the global view for them.

Usage:
  sable-worker-status            # own-lane table (default: @sable_lane==$CLAUDE_AGENT_NAME)
  sable-worker-status --mine     # explicit form of the default own-lane filter
  sable-worker-status --lane opt # panes owned by lane "opt"
  sable-worker-status --all      # every lane (the pre-dcw2 fleet-wide view)
  sable-worker-status --reap     # also kill OWN-lane panes whose @sable_status=done
  sable-worker-status --json

Env:
  SABLE_TMUX_SOCKET   tmux socket name (-L); for session isolation / tests
  SABLE_TMUX_SESSION  explicit session override (default derives per-repo via
                      sable-session, SABLE-e1e3 — listing and reaping are
                      scoped to THIS repo's fleet only)
  SABLE_STATUS_SAMPLE_INTERVAL  seconds between the two windowed-sampling
                      reads (SABLE-1kbo, default 1.5); lower for fast tests
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys
import time

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
from sable_pane_lib import (  # noqa: E402
    SessionCollision, capture_pane, pane_ready, resolve_session, session_limit_reset)

WORKER_ROLE_PREFIX = "worker"
# Tab-delimited (SABLE-exab): a space-joined format collapses an EMPTY field
# (e.g. a producer pane spawned without a bead tag) into its neighboring
# whitespace, shifting every later column left by one. Tabs never collapse,
# so an empty @sable_bead placeholder still occupies its own field.
# @sable_lane (SABLE-dcw2) is the LAST field: appended so a pane spawned before
# this column existed (no @sable_lane) simply renders a trailing empty field
# rather than shifting @sable_class/@sable_deliverable — the same tab-delimited
# discipline the fields above rely on.
_FORMAT = ("#{pane_id}\t#{@sable_role}\t#{@sable_bead}\t#{@sable_status}\t"
           "#{@sable_class}\t#{@sable_deliverable}\t#{@sable_lane}")


def tmux_base(socket: str | None) -> list[str]:
    return ["tmux", "-L", socket] if socket else ["tmux"]


def parse_worker_panes(output: str) -> list[dict]:
    """Parse `tmux list-panes -F _FORMAT` into worker/producer records.

    Worker records stay a bare {pane, bead, status} dict — the exact shape
    this function has always returned, since existing callers/tests key off
    it. Producer records (and the unrecognized-class fail-safe below)
    additionally carry "class" (and, for producers, "deliverable"), since
    reaping_decision needs them to gate the kill decision. Missing status
    defaults to 'running' (a just-spawned pane may not have set it yet).

    A pane's @sable_lane (SABLE-dcw2), when stamped, is added as "lane" — the
    key filter_by_lane keys off for the own-lane default view. It is added
    ONLY when non-empty, exactly like "class"/"deliverable": a pane spawned
    before this column (or without a resolvable lane) keeps the bare shape, so
    every pre-existing exact-shape assertion stays valid and an unattributed
    pane is surfaced only under --all."""
    workers: list[dict] = []
    for line in output.splitlines():
        parts = line.split("\t")
        if len(parts) < 2:
            continue
        pane, role = parts[0], parts[1]
        bead = parts[2] if len(parts) >= 3 else ""
        status = parts[3] if len(parts) >= 4 and parts[3] else "running"
        cls = parts[4] if len(parts) >= 5 and parts[4] else ""
        deliverable = parts[5] if len(parts) >= 6 and parts[5] else ""
        lane = parts[6] if len(parts) >= 7 and parts[6] else ""

        if cls == "manager":
            continue  # always-on manager loops are never surfaced/reaped
        if cls == "":
            if not role.startswith(WORKER_ROLE_PREFIX):
                continue  # legacy rule: role-less / non-worker panes skipped
            rec = {"pane": pane, "bead": bead, "status": status}
        elif cls == "worker":
            rec = {"pane": pane, "bead": bead, "status": status}
        elif cls == "producer":
            rec = {"pane": pane, "bead": bead, "status": status,
                   "class": "producer", "deliverable": deliverable}
        else:
            # unrecognized non-empty class: list it (a human should notice),
            # but never reap it -- see reaping_decision's fail-safe.
            rec = {"pane": pane, "bead": bead, "status": status,
                   "class": cls, "deliverable": deliverable}
        if lane:
            rec["lane"] = lane
        workers.append(rec)
    return workers


def is_done(status: str) -> bool:
    return status == "done"


def deliverable_ok(path: str) -> bool:
    """True when a producer's @sable_deliverable file exists and parses as
    valid JSON — the SABLE-e6m6 pull-authoritative detection signal (a
    written, parseable file is the one completion signal that survives a
    producer idling without ever sending a final message)."""
    if not path:
        return False
    try:
        with open(path, "r", encoding="utf-8") as fh:
            json.load(fh)
        return True
    except (OSError, ValueError):
        return False


def done_no_deliverable(workers: list[dict]) -> list[dict]:
    """Done producer panes whose deliverable is missing or not valid JSON.
    Not reaped (see reaping_decision) but surfaced so a human or manager
    notices the stall instead of the pane silently sitting there forever."""
    return [w for w in workers
            if w.get("class") == "producer" and is_done(w["status"])
            and not deliverable_ok(w.get("deliverable", ""))]


def rate_limit_stall(capture: str) -> str | None:
    """The reset-time text when `capture` shows a pane STALLED on the Claude
    Code session-rate-limit banner: the banner text is present AND the
    composer is back to its idle empty prompt (pane_ready) — proof the turn
    was cut off, not merely a banner sitting mid-scrollback while a later
    turn keeps processing (SABLE-ita7). Returns None when the banner isn't
    present, or when it IS present but the composer isn't ready yet (still
    processing — not yet stalled; v1 is a detection surface only, no
    auto-nudge)."""
    reset = session_limit_reset(capture)
    if reset is None or not pane_ready(capture):
        return None
    return reset


def flag_rate_limit_stalls(workers: list[dict], socket: str | None, capture=None) -> list[dict]:
    """Capture-pane every RUNNING worker/producer and flag one whose turn was
    cut off by the Claude Code session-rate-limit banner: its status becomes
    "stalled-rate-limit" with a "reset" field carrying the reset-time text
    (SABLE-ita7 — the SABLE-tz7h.4 worker pane read "running" for ~5 hours
    after hitting the limit, with no distinguishing signal). Done/
    done-unconfirmed panes are left untouched — a finished pane isn't
    "stalled". One capture-pane call per running pane is cheap at the pane
    counts this tool manages (SABLE_MAX_WORKERS caps the fleet at a
    handful)."""
    base = tmux_base(socket)
    cap = capture or (lambda pane: capture_pane(base, pane))
    flagged: list[dict] = []
    for w in workers:
        if w["status"] != "running":
            flagged.append(w)
            continue
        reset = rate_limit_stall(cap(w["pane"]))
        flagged.append({**w, "status": "stalled-rate-limit", "reset": reset} if reset else w)
    return flagged


def reaping_decision(workers: list[dict]) -> list[str]:
    """Panes to kill: any done worker/producer pane, EXCEPT (a) a done
    producer whose @sable_deliverable is missing or invalid — flagged via
    done_no_deliverable instead of killed — and (b) any pane carrying an
    unrecognized @sable_class — fail-safe, never reaped since this tool
    doesn't understand its lifecycle contract."""
    doomed = []
    for w in workers:
        if not is_done(w["status"]):
            continue
        cls = w.get("class")
        if cls is not None and cls != "producer":
            continue  # unrecognized class tag -- fail-safe, never reap
        if cls == "producer" and not deliverable_ok(w.get("deliverable", "")):
            continue  # done-no-deliverable -- flagged, not killed
        doomed.append(w["pane"])
    return doomed


def dedupe_panes(workers: list[dict]) -> list[dict]:
    """A grouped-session topology (`tmux new-session -t <sess> -s <alias>`
    shares one window list under two session names) makes `tmux list-panes -a`
    enumerate the SAME physical pane once per session alias. Collapse to one
    record per pane id, keeping the first occurrence, before anything reaps."""
    seen: set[str] = set()
    deduped: list[dict] = []
    for w in workers:
        if w["pane"] in seen:
            continue
        seen.add(w["pane"])
        deduped.append(w)
    return deduped


def filter_by_lane(workers: list[dict], lane: str) -> list[dict]:
    """Restrict to panes stamped @sable_lane == `lane` — the SABLE-dcw2
    own-lane view. A manager's DEFAULT sweep must see (and --reap) ONLY its
    own dispatched workers: the ownerless listing let any manager's
    sable-worker-status surface every manager's panes, so a stranded-recovery
    sweep adopted another lane's just-spawned workers as orphans, and a reap
    consumed DONE panes the OWNING manager was still event-waiting on (stall +
    who-relays-to-chuck ambiguity). A pane with no @sable_lane (empty/unstamped,
    e.g. spawned before this column) carries no "lane" key, matches no manager,
    and is therefore surfaced only under --all — never silently swept by a lane
    it can't be attributed to."""
    return [w for w in workers if w.get("lane", "") == lane]


def _runner(args: list[str]) -> str:
    return subprocess.run(args, capture_output=True, text=True, check=True).stdout


def _capture_pane(base: list[str], pane: str) -> str:
    return subprocess.run(base + ["capture-pane", "-p", "-t", pane],
                          capture_output=True, text=True).stdout


def _composer_box(capture: str) -> str | None:
    """Return the last line in the capture that looks like the composer box
    (prefixed by the tmux-native `>` or claude's `❯` prompt glyph), or None
    if no such line is present. Shared by has_pending_input and
    pending_input_text so both agree on what counts as "the box"."""
    box = None
    for line in capture.splitlines():
        s = line.strip()
        if s.startswith("❯") or s.startswith(">"):
            box = s
    return box


def has_pending_input(capture: str) -> bool:
    """True if the pane's input box currently holds unsubmitted text — the
    composer line (prefixed by the tmux-native `>` or claude's `❯` prompt
    glyph) has content beyond the glyph itself. A done worker pane must never
    be silently killed while this is true (market-brief-package-0h8k): the
    text may be a misrouted/queued instruction nobody in the lane sent, and
    destroying the pane destroys the only evidence of it."""
    box = _composer_box(capture)
    if box is None:
        return False
    return box not in ("❯", ">")


def pending_input_text(capture: str) -> str | None:
    """Return the composer box's actual content (the text after the prompt
    glyph), or None if there is no pending input. Sibling to
    has_pending_input: where that answers "is there pending input", this
    answers "what does it say" — the text itself is the evidence reap() must
    log before it is destroyed (market-brief-package-b5ow / 0h8k)."""
    box = _composer_box(capture)
    if box is None or box in ("❯", ">"):
        return None
    for glyph in ("❯", ">"):
        if box.startswith(glyph):
            return box[len(glyph):].strip()
    return box


def list_workers(socket: str | None, run=_runner, session: str | None = None) -> list[dict]:
    """Worker panes, scoped to `session` when given (SABLE-e1e3.3: with one
    fleet per repo on a shared server, a server-wide -a listing would surface
    — and --reap would kill — another repo's workers). A missing session is
    simply zero workers."""
    scope = ["-s", "-t", session] if session else ["-a"]
    try:
        out = run(tmux_base(socket) + ["list-panes", *scope, "-F", _FORMAT])
    except subprocess.CalledProcessError:
        return []
    return dedupe_panes(parse_worker_panes(out))


_DEFAULT_SAMPLE_INTERVAL = 1.5


def bead_closed(bead: str, run=_runner) -> bool | None:
    """SABLE-1kbo real-done crosscheck: a worker pane's @sable_status=done
    tag is self-reported and can be stale (a reused pane still carrying a
    prior occupant's tag before the fresh worker's init overwrites it) or
    simply premature. Returns True only when `bd show <bead>` confirms the
    bead is actually closed, False when bd resolves it but it is NOT closed
    (a genuine mismatch worth flagging), and None when the bead can't be
    resolved at all (bd missing, bead not found, malformed output) — an
    unresolvable bead fails OPEN (trust the tag) rather than punishing a
    pane over a lookup that says nothing either way. Producers are exempt
    from this check entirely (see confirm_done_status): they signal
    completion via their deliverable file (SABLE-e6m6), not a bead, and
    SABLE-exab established that a producer may have no bead at all."""
    if not bead:
        return None
    try:
        out = run(["bd", "show", bead, "--json"])
    except (subprocess.CalledProcessError, FileNotFoundError, OSError):
        return None
    try:
        data = json.loads(out)
    except ValueError:
        return None
    if isinstance(data, list):
        data = data[0] if data else {}
    if not isinstance(data, dict) or "status" not in data:
        return None
    return data["status"] == "closed"


def reconcile_samples(first: list[dict], second: list[dict]) -> list[dict]:
    """Merge two done-status samples of the same pane pool, taken a short
    window apart (SABLE-1kbo windowed sampling). Fixes two live-observed
    defects: (a) mid-turn-labeled-done — a pane that read done in the FIRST
    sample only (a stale tag from a reused pane's prior occupant, about to
    be overwritten by the fresh worker's init) is reported using the
    SECOND, fresher sample instead of the stale one; (b) omitted-live-pane —
    a pane missing from one sample (a listing race, not an actual lifecycle
    change) is still surfaced, using whichever sample saw it, instead of
    silently vanishing from the table."""
    by_pane_second = {w["pane"]: w for w in second}
    merged: list[dict] = []
    seen: set[str] = set()
    for w in first:
        seen.add(w["pane"])
        merged.append(by_pane_second.get(w["pane"], w))
    for w in second:
        if w["pane"] not in seen:
            merged.append(w)
    return merged


def confirm_done_status(worker: dict, run=_runner) -> dict:
    """Second, independent crosscheck (SABLE-1kbo) applied AFTER windowed
    sampling has already settled a pane's status: a worker/legacy pane (not
    a producer — see bead_closed) reporting done is only trusted once
    `bd show` confirms its bead is actually closed. An uncorroborated done
    is downgraded to "done-unconfirmed" — excluded from reaping_decision
    (which only kills status == "done") and visible in the CLI table for a
    human, the same idiom as the existing done-no-deliverable flag, rather
    than silently trusted off the tag alone."""
    if is_done(worker["status"]) and worker.get("class") != "producer":
        if bead_closed(worker.get("bead", ""), run=run) is False:
            return {**worker, "status": "done-unconfirmed"}
    return worker


def list_workers_confirmed(socket: str | None, run=_runner, session: str | None = None,
                            sleep=time.sleep, interval: float = _DEFAULT_SAMPLE_INTERVAL,
                            samples: int = 2) -> list[dict]:
    """The reliability layer main() uses in place of a single list_workers()
    snapshot (SABLE-1kbo) before reporting or reaping anything as done:
    samples the pane pool `samples` times, `interval` seconds apart, and
    reconciles them (see reconcile_samples), then crosschecks every settled
    done worker pane against the bead pool (see confirm_done_status)."""
    batch = list_workers(socket, run=run, session=session)
    for _ in range(samples - 1):
        sleep(interval)
        batch = reconcile_samples(batch, list_workers(socket, run=run, session=session))
    return [confirm_done_status(w, run=run) for w in batch]


_PENDING_TEXT_LOG_LIMIT = 500


def reap(panes: list[str], socket: str | None, run=_runner, capture=None) -> list[str]:
    """Kill each done pane. One holding unsubmitted composer input is NOT
    silently killed over: clear it first (so no pane ever survives reap still
    holding pending input) and flag it loudly — including the pending text
    itself, since the text IS the evidence (market-brief-package-b5ow; a
    prior version logged only the pane id and destroyed the text unrecorded)
    — then proceed with the kill. The worker is done regardless, but the
    anomaly must be visible to a human or manager, not swallowed. Returns the
    pane ids that were flagged."""
    base = tmux_base(socket)
    cap = capture or (lambda pane: _capture_pane(base, pane))
    flagged: list[str] = []
    for pane in panes:
        cap_text = cap(pane)
        if has_pending_input(cap_text):
            flagged.append(pane)
            text = pending_input_text(cap_text) or ""
            if len(text) > _PENDING_TEXT_LOG_LIMIT:
                text = text[:_PENDING_TEXT_LOG_LIMIT] + "…[truncated]"
            sys.stderr.write(
                f"sable-worker-status: pane {pane} is done but holds unsubmitted "
                f"composer input — clearing + flagging before reap "
                f"(market-brief-package-0h8k): pending text={text!r}\n")
            run(base + ["send-keys", "-t", pane, "C-u"])
        try:
            run(base + ["kill-pane", "-t", pane])
        except subprocess.CalledProcessError:
            # Already dead (e.g. a race between listing and this sweep, or a
            # concurrent reaper) — not a reason to abort the rest of the sweep.
            continue
    return flagged


def parse_client_sessions(list_clients_output: str) -> list[str]:
    """Pure parse of `tmux list-clients -F #{client_session}` output into
    the session names any client is currently attached to (SABLE-yfdn). May
    contain duplicates (multiple clients on the same session) — harmless,
    protected_windows collapses into a set."""
    return [line.strip() for line in list_clients_output.splitlines() if line.strip()]


def protected_windows(socket: str | None, run=_runner) -> set[tuple[str, str]]:
    """The (session, window_index) pairs any attached tmux client is
    currently viewing (SABLE-yfdn) — reap() must never kill a pane whose
    window is in this set; see filter_protected. A grouped-session topology
    (`tmux new-session -t <sess> -s <alias>`) gives each session alias its
    OWN current-window pointer even though the aliases share one underlying
    window list, so window_index alone isn't a safe key — it's paired with
    the client's session name."""
    base = tmux_base(socket)
    try:
        raw = run(base + ["list-clients", "-F", "#{client_session}"])
    except subprocess.CalledProcessError:
        return set()
    protected: set[tuple[str, str]] = set()
    for sess in parse_client_sessions(raw):
        try:
            idx = run(base + ["display-message", "-p", "-t", sess, "#{window_index}"]).strip()
        except subprocess.CalledProcessError:
            continue
        protected.add((sess, idx))
    return protected


def pane_location(pane: str, socket: str | None, run=_runner) -> tuple[str, str] | None:
    """(session, window_index) for a pane id, or None if it can't be
    resolved (e.g. the pane already died in a race with a concurrent
    reaper) — treated as unprotected by filter_protected, since a vanished
    pane can't be in anyone's current window."""
    base = tmux_base(socket)
    try:
        out = run(base + ["display-message", "-p", "-t", pane,
                           "#{session_name}\t#{window_index}"])
    except subprocess.CalledProcessError:
        return None
    out = out.strip()
    if "\t" not in out:
        return None
    sess, idx = out.split("\t", 1)
    return (sess, idx)


def filter_protected(panes: list[str], socket: str | None, run=_runner) -> list[str]:
    """Reap candidates with any pane currently in an attached client's
    current window removed (SABLE-yfdn). Worker windows are single-pane, so
    kill-pane destroys the whole window; if an attached client (the
    operator watching a worker finish) is on it, tmux would forcibly
    switch that client's view mid-observation. A protected pane is left
    alive for the next sweep instead of being reaped now."""
    protected = protected_windows(socket, run=run)
    if not protected:
        return panes
    return [p for p in panes if pane_location(p, socket, run=run) not in protected]


def resolve_view_lane(ns) -> str | None:
    """The lane to scope the listing/reap to (SABLE-dcw2), or None for the
    fleet-wide view. --all => None; --lane <name> => that name; otherwise (the
    default, == --mine) the caller's own $CLAUDE_AGENT_NAME. An un-laned caller
    (no CLAUDE_AGENT_NAME — e.g. the operator running it by hand) also resolves
    to None: they get the global view rather than an empty own-lane one."""
    if ns.all:
        return None
    if ns.lane:
        return ns.lane
    return (os.environ.get("CLAUDE_AGENT_NAME") or "").strip() or None


def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(prog="sable-worker-status")
    p.add_argument("--reap", action="store_true",
                   help="kill panes whose @sable_status=done")
    p.add_argument("--json", action="store_true", help="machine-readable output")
    scope = p.add_mutually_exclusive_group()
    scope.add_argument("--all", action="store_true",
                       help="list every lane's panes (default: only the caller's own lane)")
    scope.add_argument("--mine", action="store_true",
                       help="list only the caller's own lane ($CLAUDE_AGENT_NAME) — the default")
    scope.add_argument("--lane", metavar="NAME",
                       help="list only panes owned by lane NAME")
    ns = p.parse_args(sys.argv[1:] if argv is None else argv)
    socket = os.environ.get("SABLE_TMUX_SOCKET") or None
    try:
        session = resolve_session(socket=socket)
    except SessionCollision as e:
        sys.stderr.write(f"sable-worker-status: {e}\n")
        return 4

    interval = float(os.environ.get("SABLE_STATUS_SAMPLE_INTERVAL", _DEFAULT_SAMPLE_INTERVAL))
    workers = list_workers_confirmed(socket, session=session, interval=interval)
    # SABLE-dcw2: scope to the caller's own lane BEFORE anything reads or reaps,
    # so the display, the done-no-deliverable flags AND reaping_decision all
    # operate on the owned subset — a manager's --reap can never touch (and so
    # can never consume the completion signal of) another lane's pane.
    view_lane = resolve_view_lane(ns)
    if view_lane is not None:
        workers = filter_by_lane(workers, view_lane)
    workers = flag_rate_limit_stalls(workers, socket)
    dnd_panes = {w["pane"] for w in done_no_deliverable(workers)}

    if ns.json:
        print(json.dumps(workers, indent=2))
    else:
        if not workers:
            print("no worker panes")
        for w in workers:
            flag = " [done-no-deliverable]" if w["pane"] in dnd_panes else ""
            if w["status"] == "stalled-rate-limit":
                flag += f" [resets={w.get('reset', '?')}]"
            lane = w.get("lane", "-")  # SABLE-dcw2 owner column; "-" if unstamped
            print(f"{w['pane']:<8} {lane:<10} {w['bead']:<16} {w['status']}{flag}")

    if ns.reap:
        doomed = reaping_decision(workers)
        protected_count = len(doomed)
        doomed = filter_protected(doomed, socket)
        protected_count -= len(doomed)
        flagged = reap(doomed, socket)
        note = f", {len(flagged)} had pending input cleared+flagged" if flagged else ""
        dnd_note = (f", {len(dnd_panes)} producer(s) done-no-deliverable (not reaped)"
                    if dnd_panes else "")
        protected_note = (f", {protected_count} pane(s) left for next sweep "
                           "(attached client's current window)" if protected_count else "")
        sys.stderr.write(
            f"sable-worker-status: reaped {len(doomed)} done pane(s)"
            f"{note}{dnd_note}{protected_note}\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
