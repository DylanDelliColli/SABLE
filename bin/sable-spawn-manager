#!/usr/bin/env python3
"""sable-spawn-manager — stand up manager panes on demand (SABLE-dqhn.2).

sable-launch starts a Lincoln-only session (mode-neutral); THIS tool adds the
execution fleet when execution actually begins — normally driven by
/sable-execute, gated to execution mode by the mode-interlock. Each manager
opens as a DETACHED tmux window (never a split — the Lincoln window the
operator is looking at is not disturbed), with its identity env, a bypass
permission posture, the @sable_role tag, and its operating-loop kick
(shared with sable-tmux --autostart via sable_pane_lib).

Usage:
  sable-spawn-manager <role> [role...]     roles: optimus | tarzan | chuck
  sable-spawn-manager --all                all three

Env: SABLE_TMUX_SESSION (default: sable), SABLE_TMUX_SOCKET (tmux -L),
     SABLE_TMUX_PANE_CMD (stand-in command; tests), SABLE_WORKER_PERMISSION,
     SABLE_DISPATCH_READY_TIMEOUT / _SUBMIT_TRIES / _POLL_INTERVAL.
"""
from __future__ import annotations

import argparse
import os
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
from sable_pane_lib import (  # noqa: E402
    AUTONOMOUS_ROLES, KICK_TAG, deliver_text, kick_message, wait_for_ready,
)

VALID_ROLES = ("optimus", "tarzan", "chuck")


def tmux_base(socket: str | None) -> list[str]:
    return ["tmux", "-L", socket] if socket else ["tmux"]


def validate_roles(roles: list[str]) -> list[str]:
    bad = [r for r in roles if r not in VALID_ROLES]
    if bad:
        raise ValueError(f"invalid role(s) {', '.join(bad)} "
                         f"(valid: {', '.join(VALID_ROLES)})")
    return roles


def parse_existing_roles(output: str) -> set[str]:
    """Roles already present, from `list-panes -s -F '#{pane_id} #{@sable_role}'`."""
    roles = set()
    for line in output.splitlines():
        parts = line.split()
        if len(parts) >= 2:
            roles.add(parts[1])
    return roles


def plan_spawns(requested: list[str], existing: set[str]) -> tuple[list[str], list[str]]:
    to_spawn = [r for r in requested if r not in existing]
    skipped = [r for r in requested if r in existing]
    return to_spawn, skipped


def manager_command() -> str:
    override = os.environ.get("SABLE_TMUX_PANE_CMD")
    if override:
        return override
    perm = os.environ.get("SABLE_WORKER_PERMISSION", "--permission-mode bypassPermissions")
    return f"claude {perm}"


def window_args(session: str, role: str, cmd: str) -> list[str]:
    """A DETACHED named window (-d): the operator's current window is never
    stolen. Managers are windows, not splits."""
    return ["new-window", "-d", "-t", session, "-n", role,
            "-P", "-F", "#{pane_id}",
            "-e", f"CLAUDE_AGENT_NAME={role}", "-e", "CLAUDE_AGENT_ROLE=manager",
            cmd]


def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(prog="sable-spawn-manager")
    p.add_argument("roles", nargs="*", help=f"roles to spawn ({' | '.join(VALID_ROLES)})")
    p.add_argument("--all", action="store_true", help="spawn all three managers")
    ns = p.parse_args(sys.argv[1:] if argv is None else argv)

    requested = list(VALID_ROLES) if ns.all else ns.roles
    if not requested:
        p.print_help(sys.stderr)
        return 2
    try:
        validate_roles(requested)
    except ValueError as e:
        sys.stderr.write(f"sable-spawn-manager: {e}\n")
        return 2

    socket = os.environ.get("SABLE_TMUX_SOCKET") or None
    session = os.environ.get("SABLE_TMUX_SESSION") or "sable"
    base = tmux_base(socket)

    if subprocess.run(base + ["has-session", "-t", session],
                      capture_output=True).returncode != 0:
        sys.stderr.write(f"sable-spawn-manager: no '{session}' session — "
                         f"start one with: sable-launch\n")
        return 1

    listing = subprocess.run(base + ["list-panes", "-s", "-t", session,
                                     "-F", "#{pane_id} #{@sable_role}"],
                             capture_output=True, text=True).stdout
    to_spawn, skipped = plan_spawns(requested, parse_existing_roles(listing))
    for role in skipped:
        sys.stderr.write(f"sable-spawn-manager: {role} already running — skipping\n")

    ready_timeout = float(os.environ.get("SABLE_DISPATCH_READY_TIMEOUT", "25"))
    submit_tries = int(os.environ.get("SABLE_DISPATCH_SUBMIT_TRIES", "8"))
    poll_interval = float(os.environ.get("SABLE_DISPATCH_POLL_INTERVAL", "1.0"))
    cmd = manager_command()

    for role in to_spawn:
        pane = subprocess.run(base + window_args(session, role, cmd),
                              capture_output=True, text=True, check=True).stdout.strip()
        subprocess.run(base + ["set-option", "-p", "-t", pane, "@sable_role", role],
                       check=True)
        if ready_timeout > 0:
            wait_for_ready(base, pane, ready_timeout, interval=poll_interval)
        if deliver_text(base, pane, kick_message(role), KICK_TAG,
                        tries=submit_tries, interval=poll_interval):
            sys.stderr.write(f"sable-spawn-manager: {role} up in its own window, "
                             f"kicked into its operating loop\n")
        else:
            sys.stderr.write(f"sable-spawn-manager: WARNING kick to {role} ({pane}) "
                             f"may be unsubmitted\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
