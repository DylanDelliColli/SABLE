#!/usr/bin/env python3
"""sable-spawn-manager — stand up manager panes on demand (SABLE-dqhn.2).

sable-launch starts a Lincoln-only session (mode-neutral); THIS tool adds the
execution fleet when execution actually begins — normally driven by
/sable-execute, gated to execution mode by the mode-interlock. Each manager
opens as a DETACHED tmux window (never a split — the Lincoln window the
operator is looking at is not disturbed), with its identity env, a bypass
permission posture, the @sable_role tag, and its operating-loop kick
(shared with sable-tmux --autostart via sable_pane_lib).

This same helper also spawns bounded PRODUCER panes (SABLE-tz7h.1) — single-shot
analysis roles like victor that write one deliverable and stop, rather than
looping managers. A producer's kick carries only the lifecycle contract (write
deliverable, flag done, exit); its task brief arrives separately via sable-msg
once the pane is ready.

Usage:
  sable-spawn-manager <role> [role...]     roles: optimus | tarzan | chuck
  sable-spawn-manager --all                all three
  sable-spawn-manager victor --deliverable PATH [--model TIER]
                                            bounded producer (--deliverable required)

Env: SABLE_TMUX_SESSION (default: sable), SABLE_TMUX_SOCKET (tmux -L),
     SABLE_TMUX_PANE_CMD (stand-in command; tests), SABLE_WORKER_PERMISSION,
     SABLE_DISPATCH_READY_TIMEOUT / _SUBMIT_TRIES / _POLL_INTERVAL.
"""
from __future__ import annotations

import argparse
import os
import re
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
from sable_pane_lib import (  # noqa: E402
    AUTONOMOUS_ROLES, KICK_TAG, SessionCollision, deliver_text, kick_message,
    repo_root, resolve_session, wait_for_ready,
)
from sable_registry_lib import (  # noqa: E402
    FLEET_PROJECT_ONLY_REMEDY, fleet_project_only, sable_registry_path,
)

VALID_ROLES = ("optimus", "tarzan", "chuck")

# Producer roles (SABLE-tz7h.1, architecture.json decisions 1+2): bounded,
# single-shot analysis panes spawned through this SAME helper rather than a
# sibling script (avoids Duplicate Code — one module owns windows/readiness/
# kick/registry for every pane class). v1 scope is victor-only; sherlock/columbo
# adopt fan-out later only if the wedge beats the baseline (Speculative
# Generality guard, decision 6).
PRODUCER_ROLES = ("victor",)
ALL_ROLES = VALID_ROLES + PRODUCER_ROLES
DEFAULT_PRODUCER_MODEL = "sonnet"

# --- Instance-entry registry writer (market-brief-package-73t4, Lincoln ruling
# 2026-07-07, mechanism (b) EXPLICIT INSTANCE REGISTRATION). When a manager role
# is spawned/respawned as a SECOND live instance, the harness may assign an
# instance-suffixed identity (tarzan-2, optimus-3). lib-identity.sh resolves a
# manager ONLY via an exact agents.yaml key match (privilege NEVER derives from a
# name pattern), so an unregistered 'tarzan-2' resolves as a worker and the
# pre-push gate denies its push. The FIX is here, in the spawn tooling: at spawn
# time we WRITE the instance's own agents.yaml entry (mirroring its base
# manager's type), so the UNCHANGED exact-match lookup resolves it. The running
# session never registers itself (constraint 2); this writer is spawn-tooling
# only and is wired into no hook.
MANAGER_TYPES = {"epic_manager", "one_off_manager", "integrator", "strategist",
                 "cockpit"}

# A trailing -<digits> is a spawn-assigned instance suffix. Used ONLY at WRITE
# time (to find the base entry to mirror) and for diagnostics — NEVER to grant
# privilege at resolution time.
_INSTANCE_RE = re.compile(r"^(?P<base>.+)-(?P<n>\d+)$")


def agents_yaml_path() -> str:
    """Runtime registry path — project-first resolver shared with the hooks
    (SABLE_AGENTS_YAML override honored, else the repo's own agents.yaml, else
    ~/.claude/sable/agents.yaml). See bin/sable_registry_lib.py, the python
    mirror of hooks/multi-manager/lib-registry-path.sh (SABLE-59t6.1)."""
    return sable_registry_path()


# Exit code for the v1 fleet-boundary refusal (SABLE-59t6.4); distinct from the
# tool's other codes (1 no-session, 2 usage, 3 register-self, 4 collision).
FLEET_BOUNDARY_EXIT = 6


def fleet_boundary_refusal(base: str | None = None) -> str | None:
    """The v1 fleet-boundary remedy (FLEET_PROJECT_ONLY_REMEDY) when EVERY
    operation of this tool must refuse — the registry resolves to a PROJECT
    registry and no global install exists (SABLE-59t6.4) — else None. The whole
    tool is fleet tooling: it stands managers/producers up into the shared tmux
    session, which needs the global registry + dispatch dir a project-only
    install lacks. Scope detection is the 59t6.1 resolver's (fleet_project_only);
    bin/sable-launch enforces the identical boundary on its session door via the
    resolver's fleet-preflight CLI. The escape hatch (export SABLE_AGENTS_YAML)
    flips the scope to 'override' and lifts this."""
    return FLEET_PROJECT_ONLY_REMEDY if fleet_project_only(base) else None


def strip_instance_suffix(name: str) -> str:
    """Base registry name of a spawn-assigned instance (tarzan-2 -> tarzan).
    Diagnostic + write-time base lookup ONLY. Returns name unchanged when it
    carries no -<digits> suffix (tarzan, tarzan-abc, general-purpose)."""
    m = _INSTANCE_RE.match(name or "")
    return m.group("base") if m else (name or "")


def parse_registry(text: str) -> dict:
    """Minimal agents.yaml reader mirroring lib-identity's awk shape: a 2-space
    '<name>:' key under 'agents:', with 4-space 'type:' / 'instance_of:' beneath.
    No PyYAML dependency (matches the awk parser the hooks use)."""
    agents: dict = {}
    cur = None
    for raw in text.splitlines():
        m = re.match(r"^  ([A-Za-z0-9_-]+):\s*$", raw)
        if m:
            cur = m.group(1)
            agents[cur] = {}
            continue
        if cur is not None:
            mt = re.match(r"^    type:\s*([^\s#]+)", raw)
            if mt:
                agents[cur]["type"] = mt.group(1)
                continue
            mi = re.match(r"^    instance_of:\s*([^\s#]+)", raw)
            if mi:
                agents[cur]["instance_of"] = mi.group(1)
    return agents


def base_manager_type(text: str, name: str):
    """The registry type of <name>'s base entry, but only when <name> is an
    instance (<base>-<N>) AND <base> is a registered MANAGER. Else None."""
    base = strip_instance_suffix(name)
    if base == name:
        return None
    entry = parse_registry(text).get(base)
    if entry and entry.get("type") in MANAGER_TYPES:
        return entry["type"]
    return None


def register_instance(name: str, *, actor: str | None = None,
                      yaml_path: str | None = None) -> str:
    """Spawn-time writer (mechanism b): register instance <name> with its base
    manager's type, tagged instance_of:<base>, so lib-identity's UNCHANGED
    exact-match lookup resolves it as a manager. Idempotent. Returns a status:

      refused-self         actor == name — a session may not register ITSELF
                           (privilege comes from the operator/tooling-owned
                           registry; self-registration is self-elevation).
      noop-not-instance    <name> has no -<digits> suffix (not an instance)
      noop-no-registry     agents.yaml unreadable
      noop-base-not-manager  base is absent or not a manager type
      exists               <name> already registered (no change)
      registered           entry written
    """
    if actor is not None and actor == name:
        return "refused-self"
    base = strip_instance_suffix(name)
    if base == name:
        return "noop-not-instance"
    path = yaml_path or agents_yaml_path()
    try:
        with open(path, "r", encoding="utf-8") as fh:
            text = fh.read()
    except OSError:
        return "noop-no-registry"
    if name in parse_registry(text):
        return "exists"
    btype = base_manager_type(text, name)
    if not btype:
        return "noop-base-not-manager"
    entry = f"  {name}:\n    type: {btype}\n    instance_of: {base}\n"
    lines = text.splitlines(keepends=True)
    out, inserted = [], False
    for line in lines:
        out.append(line)
        if not inserted and re.match(r"^agents:\s*$", line):
            out.append(entry)          # first child of the agents: mapping
            inserted = True
    if not inserted:                    # no agents: root (unexpected) — seed one
        if out and not out[-1].endswith("\n"):
            out.append("\n")
        out.append("agents:\n" + entry)
    with open(path, "w", encoding="utf-8") as fh:
        fh.write("".join(out))
    return "registered"


def prune_stale_instances(live_names, *, yaml_path: str | None = None) -> list:
    """Remove instance entries (those carrying instance_of) whose key is NOT in
    live_names. Base / hand-authored entries (no instance_of) are never touched.
    Returns the pruned names. The prune path for reap / respawn."""
    path = yaml_path or agents_yaml_path()
    try:
        with open(path, "r", encoding="utf-8") as fh:
            text = fh.read()
    except OSError:
        return []
    live = set(live_names or [])
    reg = parse_registry(text)
    doomed = {n for n, e in reg.items() if "instance_of" in e and n not in live}
    if not doomed:
        return []
    lines = text.splitlines(keepends=True)
    out, pruned, i, n = [], [], 0, len(lines)
    while i < n:
        m = re.match(r"^  ([A-Za-z0-9_-]+):\s*$", lines[i])
        if m and m.group(1) in doomed:
            pruned.append(m.group(1))
            i += 1
            while i < n and re.match(r"^    \S", lines[i]):   # its type/instance_of body
                i += 1
            continue
        out.append(lines[i])
        i += 1
    with open(path, "w", encoding="utf-8") as fh:
        fh.write("".join(out))
    return pruned


def tmux_base(socket: str | None) -> list[str]:
    return ["tmux", "-L", socket] if socket else ["tmux"]


def validate_roles(roles: list[str]) -> list[str]:
    bad = [r for r in roles if r not in ALL_ROLES]
    if bad:
        raise ValueError(f"invalid role(s) {', '.join(bad)} "
                         f"(valid: {', '.join(ALL_ROLES)})")
    return roles


def sable_class(role: str) -> str:
    """The @sable_class tag for a role (architecture.json decision 2): pane
    lifecycle classification lives here as an explicit tag rather than name-
    prefix parsing, so a future producer needs zero edits in the reaper."""
    return "producer" if role in PRODUCER_ROLES else "manager"


def missing_deliverable_error(requested: list[str], deliverable: str | None) -> str | None:
    """None when fine; else the hard-error message for a producer role
    requested without --deliverable (architecture.json decision 1: the
    contract requires an output path for every bounded producer pane)."""
    producer_requested = [r for r in requested if r in PRODUCER_ROLES]
    if producer_requested and not deliverable:
        return (f"--deliverable PATH required for producer role(s) "
                f"{', '.join(producer_requested)}")
    return None


def parse_existing_roles(output: str) -> set[str]:
    """Roles already present, from `list-panes -s -F '#{pane_id} #{@sable_role}'`."""
    roles = set()
    for line in output.splitlines():
        parts = line.split()
        if len(parts) >= 2:
            roles.add(parts[1])
    return roles


def plan_spawns(requested: list[str], existing: set[str]) -> tuple[list[str], list[str]]:
    to_spawn = [r for r in requested if r not in existing]
    skipped = [r for r in requested if r in existing]
    return to_spawn, skipped


def manager_command() -> str:
    """The command used to launch a manager pane. Managers ALWAYS run on Opus
    (SABLE-gbd) — the per-bead model ladder (SABLE.md 6.9) governs the workers
    a manager dispatches, never the manager's own model. SABLE_TMUX_PANE_CMD is
    a full override for tests only and is exempt from the pin."""
    override = os.environ.get("SABLE_TMUX_PANE_CMD")
    if override:
        return override
    perm = os.environ.get("SABLE_WORKER_PERMISSION", "--permission-mode bypassPermissions")
    return f"claude --model opus {perm}"


def producer_command(model: str) -> str:
    """A producer's command line pins its CALLER-CHOSEN model tier
    (architecture.json decision 1) — unlike manager_command, which always
    pins Opus regardless of any tier argument (SABLE-gbd: the model ladder
    is for bounded producers and workers, never for the always-on manager
    fleet)."""
    override = os.environ.get("SABLE_TMUX_PANE_CMD")
    if override:
        return override
    perm = os.environ.get("SABLE_WORKER_PERMISSION", "--permission-mode bypassPermissions")
    return f"claude --model {model} {perm}".strip()


def window_args(session: str, role: str, cmd: str) -> list[str]:
    """A DETACHED named window (-d): the operator's current window is never
    stolen. Managers/producers are windows, not splits. Producer roles get
    CLAUDE_AGENT_ROLE=producer; managers keep CLAUDE_AGENT_ROLE=manager
    byte-identical to before (regression-locked)."""
    agent_role = "producer" if role in PRODUCER_ROLES else "manager"
    return ["new-window", "-d", "-t", session, "-n", role,
            "-P", "-F", "#{pane_id}",
            "-e", f"CLAUDE_AGENT_NAME={role}", "-e", f"CLAUDE_AGENT_ROLE={agent_role}",
            cmd]


def main(argv: list[str] | None = None) -> int:
    p = argparse.ArgumentParser(prog="sable-spawn-manager")
    p.add_argument("roles", nargs="*", help=f"roles to spawn ({' | '.join(ALL_ROLES)})")
    p.add_argument("--all", action="store_true", help="spawn all three managers")
    p.add_argument("--deliverable", metavar="PATH",
                   help="output path for a producer role's deliverable "
                        "(required for producer roles, e.g. victor)")
    p.add_argument("--model", metavar="TIER",
                   help="model tier for a producer role's pane (default: "
                        f"{DEFAULT_PRODUCER_MODEL})")
    p.add_argument("--register-instance", metavar="NAME",
                   help="register a spawn-assigned manager instance (e.g. tarzan-2) "
                        "into agents.yaml so lib-identity resolves it as a manager "
                        "(mechanism b; a running session may not register itself)")
    p.add_argument("--prune-instances", action="store_true",
                   help="prune stale instance entries whose panes are no longer live")
    ns = p.parse_args(sys.argv[1:] if argv is None else argv)

    # --- v1 fleet boundary (SABLE-59t6.4): refuse EVERY sable-spawn-manager
    # operation under a project-only install (project registry, no global
    # install, no SABLE_AGENTS_YAML override). This tool only ever stands panes
    # up into the shared fleet session; none of it works without the global
    # machinery. Solo-loop paths (Lincoln, producer SUBAGENTS, planning) never
    # reach this tool, so no non-fleet path is gated here.
    remedy = fleet_boundary_refusal()
    if remedy:
        sys.stderr.write(f"sable-spawn-manager: {remedy}\n")
        return FLEET_BOUNDARY_EXIT

    # --- Instance registry maintenance (73t4). These are the spawn/respawn
    # tooling entry points into the writer; they never spawn a pane.
    if ns.register_instance:
        actor = (os.environ.get("SABLE_REGISTER_ACTOR")
                 or os.environ.get("CLAUDE_AGENT_NAME") or "") or None
        status = register_instance(ns.register_instance, actor=actor)
        sys.stderr.write(
            f"sable-spawn-manager: register-instance {ns.register_instance}: {status}\n")
        return 3 if status == "refused-self" else 0

    socket = os.environ.get("SABLE_TMUX_SOCKET") or None
    base = tmux_base(socket)
    try:
        session = resolve_session(socket=socket)
    except SessionCollision as e:
        sys.stderr.write(f"sable-spawn-manager: {e}\n")
        return 4

    if ns.prune_instances:
        # session-scoped (SABLE-e1e3): another repo's live roles must not keep
        # THIS repo's stale registry entries alive
        listing = subprocess.run(base + ["list-panes", "-s", "-t", session,
                                         "-F", "#{@sable_role}"],
                                 capture_output=True, text=True)
        live = {r for r in listing.stdout.split() if r} if listing.returncode == 0 else set()
        pruned = prune_stale_instances(live)
        sys.stderr.write(
            f"sable-spawn-manager: pruned {len(pruned)} stale instance "
            f"entr{'y' if len(pruned) == 1 else 'ies'}"
            f"{': ' + ', '.join(pruned) if pruned else ''}\n")
        return 0

    requested = list(VALID_ROLES) if ns.all else ns.roles
    if not requested:
        p.print_help(sys.stderr)
        return 2
    try:
        validate_roles(requested)
    except ValueError as e:
        sys.stderr.write(f"sable-spawn-manager: {e}\n")
        return 2

    deliverable_err = missing_deliverable_error(requested, ns.deliverable)
    if deliverable_err:
        sys.stderr.write(f"sable-spawn-manager: {deliverable_err}\n")
        return 2

    if subprocess.run(base + ["has-session", "-t", session],
                      capture_output=True).returncode != 0:
        sys.stderr.write(f"sable-spawn-manager: no '{session}' session — "
                         f"start one with: sable-launch\n")
        return 1

    listing = subprocess.run(base + ["list-panes", "-s", "-t", session,
                                     "-F", "#{pane_id} #{@sable_role}"],
                             capture_output=True, text=True).stdout
    to_spawn, skipped = plan_spawns(requested, parse_existing_roles(listing))
    for role in skipped:
        sys.stderr.write(f"sable-spawn-manager: {role} already running — skipping\n")

    ready_timeout = float(os.environ.get("SABLE_DISPATCH_READY_TIMEOUT", "25"))
    submit_tries = int(os.environ.get("SABLE_DISPATCH_SUBMIT_TRIES", "8"))
    poll_interval = float(os.environ.get("SABLE_DISPATCH_POLL_INTERVAL", "1.0"))
    mgr_cmd = manager_command()
    producer_model = ns.model or DEFAULT_PRODUCER_MODEL

    root = repo_root()
    for role in to_spawn:
        is_producer = role in PRODUCER_ROLES
        cmd = producer_command(producer_model) if is_producer else mgr_cmd
        pane = subprocess.run(base + window_args(session, role, cmd),
                              capture_output=True, text=True, check=True).stdout.strip()
        subprocess.run(base + ["set-option", "-p", "-t", pane, "@sable_role", role],
                       check=True)
        subprocess.run(base + ["set-option", "-p", "-t", pane, "@sable_class",
                               sable_class(role)], check=True)
        if is_producer:
            subprocess.run(base + ["set-option", "-p", "-t", pane, "@sable_deliverable",
                                   ns.deliverable], check=True)
        if root:
            subprocess.run(base + ["set-option", "-p", "-t", pane, "@sable_repo", root],
                           check=True)
        # Constraint 3 (73t4): read the pane's ACTUAL assigned name post-spawn and
        # register it when the harness suffixed it into an instance. For a bare
        # role this is a no-op (base == name), so the default single-instance flow
        # writes nothing to the registry.
        assigned = subprocess.run(
            base + ["display-message", "-p", "-t", pane, "#{@sable_role}"],
            capture_output=True, text=True).stdout.strip() or role
        register_instance(assigned, actor=os.environ.get("CLAUDE_AGENT_NAME"))
        if ready_timeout > 0:
            wait_for_ready(base, pane, ready_timeout, interval=poll_interval)
        kick = kick_message(role, deliverable=ns.deliverable if is_producer else None)
        if deliver_text(base, pane, kick, KICK_TAG,
                        tries=submit_tries, interval=poll_interval):
            sys.stderr.write(f"sable-spawn-manager: {role} up in its own window, "
                             f"kicked into its operating loop\n")
        else:
            sys.stderr.write(f"sable-spawn-manager: WARNING kick to {role} ({pane}) "
                             f"may be unsubmitted\n")
    return 0


if __name__ == "__main__":
    sys.exit(main())
