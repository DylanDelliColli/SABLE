#!/usr/bin/env bash
# sable-launch — the memorable session door (SABLE-njiv, SABLE-ssws.2,
# mode-neutral SABLE-dqhn.1).
#
# No arguments: START your SABLE session — a tmux session holding ONLY the
# lincoln pane (the one agent you talk to), then attach. Mode-neutral:
# launching says nothing about planning vs execution, and no managers are
# spawned or kicked. Managers appear later, on demand, in their OWN windows
# (sable-spawn-manager — normally invoked by /sable-execute); peek at them
# with sable-view. Re-running is safe: an existing session is reused.
#
# With a role argument: the advanced single-pane door — launch one identity
# claude session by hand (e.g. a solo lincoln, or re-launching one pane). A
# session must NEVER launch unnamed: an unnamed lead was the root cause of a
# live identity-bleed incident (outbound messages mis-derived their sender).
#
# Usage:
#   sable-launch [--no-attach]           start (or reuse) your Lincoln session
#   sable-launch <role> [claude-args...] advanced: one identity claude session
#     role   lincoln | chuck
#   sable-launch --help
#
# Env: SABLE_TMUX_SESSION (explicit override; default derives per-repo via
#      sable-session — sable-<repo-basename>, so different repos get different
#      fleets, SABLE-e1e3), SABLE_TMUX_SOCKET (tmux -L),
#      SABLE_TMUX_BIN (override the sable-tmux helper; tests).

set -u

usage() {
  cat <<'EOF'
sable-launch — start your SABLE session (Lincoln only, mode-neutral).

Usage:
  sable-launch                start the tmux session (create if needed) + attach
  sable-launch --no-attach    bring the session up without attaching
  sable-launch <role> [claude-args...]
                              advanced: launch ONE identity claude session
                              (role: lincoln | chuck)
  sable-launch --help

The session form creates a tmux session holding ONLY the lincoln pane — the
agent you talk to, whether you are planning or executing. Managers are NOT
started here: they spawn on demand into their own hidden windows
(sable-spawn-manager, normally driven by /sable-execute). Deep-dive into them
with `sable-view`, typically from a second terminal.
The role form sets CLAUDE_AGENT_NAME=<role> and CLAUDE_AGENT_ROLE=manager and
execs `claude` directly.
EOF
}

# --- Parse. Bare / --no-attach -> session form. -h/--help -> usage. A known
#     role -> single-pane form. Any other leading claude flag -> single-pane
#     form with the default role (back-compat). Unknown role -> error. ---
MODE="session"
NO_ATTACH=0
ROLE="lincoln"
case "${1:-}" in
  -h|--help)     usage; exit 0 ;;
  "")            MODE="session" ;;
  --no-attach)   MODE="session"; NO_ATTACH=1; shift ;;
  lincoln|chuck) MODE="role"; ROLE="$1"; shift ;;
  -*)            MODE="role" ;;   # leading claude flag -> default role, pass through
  *) printf 'sable-launch: unknown role %s (valid roles: lincoln, chuck)\n\n' "$1" >&2
     usage >&2
     exit 2 ;;
esac

if [ "$MODE" = "role" ]; then
  export CLAUDE_AGENT_NAME="$ROLE"
  export CLAUDE_AGENT_ROLE="manager"
  command -v claude >/dev/null 2>&1 || { printf 'sable-launch: `claude` not found on PATH.\n' >&2; exit 127; }
  printf 'sable-launch: launching as %s (role=manager)\n' "$ROLE" >&2
  exec claude "$@"
fi

# --- Session form ---
# v1 fleet boundary (SABLE-59t6.4): the session door is a FLEET entry point —
# managers spawn into this session and rely on the global registry + dispatch
# dir. Under a PROJECT-only install (registry resolves to a project agents.yaml
# and no global install exists), refuse with the shared remedy: the fleet cannot
# resolve its global machinery here. Solo work never reaches this point — the
# role form (`sable-launch <role>`) returned above, and planning / producer
# subagents never invoke sable-launch. Scope detection is delegated to the
# 59t6.1 resolver's python mirror (its `fleet-preflight` CLI), reached as a
# sibling of this script (realpath-resolved so the ~/.local/bin symlink still
# finds the non-symlinked lib, mirroring the python tools' realpath(__file__)).
# Only the explicit refuse code (3) blocks; any other failure fails OPEN so a
# missing interpreter never wedges the launcher.
SELF="${BASH_SOURCE[0]}"
command -v realpath >/dev/null 2>&1 && SELF="$(realpath "$SELF" 2>/dev/null || printf '%s' "$SELF")"
REG_LIB="${SELF%/*}/sable_registry_lib.py"
if command -v python3 >/dev/null 2>&1 && [ -f "$REG_LIB" ]; then
  REMEDY="$(python3 "$REG_LIB" fleet-preflight 2>/dev/null)"; PF=$?
  if [ "$PF" -eq 3 ]; then
    printf 'sable-launch: %s\n' "$REMEDY" >&2
    exit 3
  fi
fi

command -v tmux >/dev/null 2>&1 || {
  printf 'sable-launch: tmux not found on PATH — the warm-pane session needs it (e.g. apt install tmux / brew install tmux).\n' >&2
  exit 127
}

# Session name: explicit env wins; otherwise derive per-repo via the
# sable-session resolver (sable-<repo-basename> + collision guard, SABLE-e1e3).
# Resolver lookup mirrors the sable-tmux lookup below: sibling first, then PATH.
if [ -n "${SABLE_TMUX_SESSION:-}" ]; then
  SESSION="$SABLE_TMUX_SESSION"
else
  SS="${BASH_SOURCE[0]%/*}/sable-session"
  if [ -x "$SS" ]; then
    SESSION="$("$SS")" || exit $?
  elif command -v sable-session >/dev/null 2>&1; then
    SESSION="$(sable-session)" || exit $?
  else
    SESSION="sable"
  fi
fi
TMUX_CMD=(tmux)
[ -n "${SABLE_TMUX_SOCKET:-}" ] && TMUX_CMD=(tmux -L "$SABLE_TMUX_SOCKET")

if "${TMUX_CMD[@]}" has-session -t "$SESSION" 2>/dev/null; then
  printf 'sable-launch: session %s already up — reusing it.\n' "$SESSION" >&2
else
  # Resolve the layout helper: env override (tests) -> sibling (repo checkout
  # or the ~/.local/bin symlink dir, where bin-install links all tools) -> PATH.
  SIBLING="${BASH_SOURCE[0]%/*}/sable-tmux"
  if [ -n "${SABLE_TMUX_BIN:-}" ]; then
    ST="$SABLE_TMUX_BIN"
  elif [ -x "$SIBLING" ]; then
    ST="$SIBLING"
  elif command -v sable-tmux >/dev/null 2>&1; then
    ST="sable-tmux"
  else
    printf 'sable-launch: sable-tmux not found (looked next to this script and on PATH).\n' >&2
    exit 127
  fi
  printf 'sable-launch: bringing up session %s (lincoln pane only)...\n' "$SESSION" >&2
  "$ST" --roles lincoln --session "$SESSION" || exit $?
fi

if [ "$NO_ATTACH" = "1" ]; then
  printf 'sable-launch: session %s up. Attach with: tmux%s attach -t %s\n' \
    "$SESSION" "${SABLE_TMUX_SOCKET:+ -L $SABLE_TMUX_SOCKET}" "$SESSION" >&2
  exit 0
fi

if [ -n "${TMUX:-}" ]; then
  CUR="$("${TMUX_CMD[@]}" display-message -p '#S' 2>/dev/null || true)"
  if [ "$CUR" = "$SESSION" ]; then
    printf 'sable-launch: you are already inside session %s.\n' "$SESSION" >&2
    exit 0
  fi
  exec "${TMUX_CMD[@]}" switch-client -t "$SESSION"
fi

exec "${TMUX_CMD[@]}" attach -t "$SESSION"
