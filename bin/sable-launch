#!/usr/bin/env bash
# sable-launch — one-command operator entry point for a standalone SABLE session
# (SABLE-njiv).
#
# Replaces the hand-copied `CLAUDE_AGENT_NAME=... CLAUDE_AGENT_ROLE=manager claude`
# aliases so a session NEVER launches without its identity — an unnamed lead was
# the root cause of a live identity-bleed incident (outbound messages mis-derived
# their sender, dropping operational directives).
#
# The normal execution bring-up is `sable-tmux --autostart`, which launches every
# role pane with its identity set. sable-launch remains for launching a single
# role by hand (e.g. a solo lincoln session, or re-launching one pane).
#
# Usage:
#   sable-launch [role] [claude-args...]
#     role   lincoln (default) — the orchestrator/lead session you talk to
#            chuck             — the merge-queue role (normally a sable-tmux pane)
#   sable-launch --help

set -u

usage() {
  cat <<'EOF'
sable-launch — launch a SABLE session with the correct agent identity + env.

Usage:
  sable-launch [role] [claude-args...]
    role   lincoln (default) — the orchestrator/lead session you talk to
           chuck             — the merge-queue role (normally a sable-tmux pane)
  sable-launch --help

Sets CLAUDE_AGENT_NAME=<role> and CLAUDE_AGENT_ROLE=manager so the session has a
stable identity. All other arguments are passed through to `claude`. The full
warm-pane session (all four roles) is launched by `sable-tmux --autostart`.
EOF
}

# --- Parse role / help. First token: -h/--help -> usage; a known role -> consume;
#     a leading claude flag or no args -> default role + pass through; anything
#     else -> unknown role error. ---
ROLE="lincoln"
case "${1:-}" in
  -h|--help) usage; exit 0 ;;
  lincoln|chuck) ROLE="$1"; shift ;;
  -*) : ;;   # leading claude flag -> default role, pass through
  "") : ;;   # no args -> default role
  *) printf 'sable-launch: unknown role %s (valid roles: lincoln, chuck)\n\n' "$1" >&2
     usage >&2
     exit 2 ;;
esac

export CLAUDE_AGENT_NAME="$ROLE"
export CLAUDE_AGENT_ROLE="manager"

command -v claude >/dev/null 2>&1 || { printf 'sable-launch: `claude` not found on PATH.\n' >&2; exit 127; }

printf 'sable-launch: launching as %s (role=manager)\n' "$ROLE" >&2
exec claude "$@"
