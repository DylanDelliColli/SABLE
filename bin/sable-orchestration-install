#!/usr/bin/env bash
# sable-orchestration-install — install (or uninstall) the complete Orchestration layer.
#
# Installs the full manager-tier layer into ./.claude (project, default) or
# ~/.claude (--user): all multi-manager hooks, the agents.yaml registry, the SABLE
# skills (/sable-plan, /sable-execute, /columbo, /gaudi, ...), and the four
# warm-pane roles (lincoln, optimus, tarzan, chuck) with identity injection.
# The settings snippet is merged idempotently into the scope's settings file
# (backed up + validated; existing entries never clobbered).
#
# Execution runs on the tmux warm-pane topology — the only topology (see
# TMUX-AGENTS-DESIGN.md): bring the session up with `sable-tmux --autostart`.
#
# install.sh delegates here for the Orchestration tier; you can also run it directly.
# Turn orchestration off at runtime WITHOUT uninstalling: export SABLE_ORCHESTRATION=off
#
# Usage:
#   sable-orchestration-install [--project|--user] [--uninstall] [--help]
#
# Env (mainly for tests):
#   SABLE_PROJECT_DIR   project root for --project scope (default: $PWD)
#   CLAUDE_USER_DIR     user config dir for --user scope (default: ~/.claude)
#   SABLE_REPO_DIR      repo root to install artifacts from (default: derived
#                       from this script's location) — test-only override

set -eu

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-$0}")" && pwd)"
REPO="${SABLE_REPO_DIR:-$(cd "$SCRIPT_DIR/.." && pwd)}"

usage() {
    sed -n '2,24p' "$0" | sed 's/^# \{0,1\}//'
}

SCOPE="project"
UNINSTALL=0
for arg in "${@:-}"; do
    case "$arg" in
        --project)          SCOPE="project" ;;
        --user)             SCOPE="user" ;;
        --uninstall)        UNINSTALL=1 ;;
        -h|--help)          usage; exit 0 ;;
        "")                 ;;
        --teams|--subagent|--nested)
            echo "sable-orchestration-install: '$arg' was retired — the tmux warm-pane path is the only execution layout (see TMUX-AGENTS-DESIGN.md)" >&2; exit 1 ;;
        *)                  echo "sable-orchestration-install: unknown argument '$arg'" >&2; exit 1 ;;
    esac
done

if [ "$SCOPE" = "user" ]; then
    BASE="${CLAUDE_USER_DIR:-$HOME/.claude}"
    SETTINGS="$BASE/settings.json"
    # --user hook commands are rewritten to the absolute BASE (byte-identical
    # to pre-SABLE-59t6.2 behavior — there's no portable placeholder for ~/.claude).
    SNIPPET_BASE="$BASE"
else
    PROJECT="${SABLE_PROJECT_DIR:-$PWD}"
    BASE="$PROJECT/.claude"
    # Project scope writes the COMMITTED settings.json (SABLE-59t6.2), so hook
    # commands must be portable across clones/machines: root them at the
    # literal ${CLAUDE_PROJECT_DIR} placeholder Claude Code expands at runtime,
    # never this machine's absolute path.
    SETTINGS="$BASE/settings.json"
    SNIPPET_BASE='${CLAUDE_PROJECT_DIR}/.claude'
fi
SKILLS="$BASE/skills"
HOOKS_DIR="$BASE/hooks/multi-manager"
AGENTS_DIR="$BASE/agents"
SNIPPET="$REPO/templates/multi-manager/settings-snippet.json"

# Retired-artifact list (SABLE-gsqj): names this repo used to ship into a scope
# but no longer does. Upgrading over a pre-existing scope is purely additive
# otherwise — these must be actively retired on every plain install, not just
# --uninstall, or they stay live (e.g. a deleted poll hook still registered
# in settings, or a retired manager def the Agent tool still offers).
RETIRED_HOOK_FILES="inbox-injection.sh inbox-injection-precompact.sh"
RETIRED_AGENT_DEFS="optimus.md tarzan.md chuck.md"

# Merge a settings snippet's hooks into the target settings file, idempotently.
# Rewrites the snippet's ~/.claude paths to BASE_DIR (the absolute BASE for
# --user scope; the literal ${CLAUDE_PROJECT_DIR}/.claude placeholder for
# --project scope, so the committed settings.json stays portable). Idempotency keys on
# (event, matcher, command-basename) so a hook registered under two matchers (e.g.
# mode-interlock.sh under both Bash and Agent) is preserved, while a re-run adds
# nothing. Backs up, validates JSON, never clobbers existing entries.
#
# $4 (optional) is a space-separated list of hook basenames to leave OUT of the
# merge entirely — hooks this run REFUSED to install because their sibling
# library closure could not be satisfied (SABLE-nn54x). Registering one of those
# would wire an inert gate, which is worse than no gate at all.
merge_snippet() {
    SETTINGS_PATH="$1" SNIPPET_PATH="$2" BASE_DIR="$3" SKIP_MARKERS="${4:-}" python3 - <<'PY'
import json, os, shutil
settings = os.environ['SETTINGS_PATH']
with open(os.environ['SNIPPET_PATH']) as f: snip = json.load(f)
base = os.environ['BASE_DIR']
skip = set(os.environ.get('SKIP_MARKERS', '').split())
data = {}
if os.path.exists(settings):
    shutil.copy(settings, settings + '.bak')
    try:
        with open(settings) as f: data = json.load(f)
    except Exception:
        data = {}
hooks = data.setdefault('hooks', {})
def marker(cmd): return (cmd or '').rsplit('/', 1)[-1]
for event, blocks in snip.get('hooks', {}).items():
    ev = hooks.get(event)
    if not isinstance(ev, list):
        ev = hooks[event] = []
    existing = set()
    for b in ev:
        if isinstance(b, dict):
            bm = b.get('matcher', '')
            for h in b.get('hooks', []):
                if isinstance(h, dict): existing.add((bm, marker(h.get('command', ''))))
    for b in blocks:
        if not isinstance(b, dict): continue
        m = b.get('matcher', '')
        target = next((x for x in ev if isinstance(x, dict) and x.get('matcher', '') == m), None)
        if target is None:
            target = {'matcher': m, 'hooks': []}; ev.append(target)
        tl = target.setdefault('hooks', [])
        for h in b.get('hooks', []):
            if not isinstance(h, dict): continue
            cmd = (h.get('command', '') or '').replace('~/.claude', base)
            if marker(cmd) in skip: continue
            key = (m, marker(cmd))
            if key in existing: continue
            existing.add(key)
            tl.append({**h, 'command': cmd})
out = json.dumps(data, indent=2); json.loads(out)
os.makedirs(os.path.dirname(settings), exist_ok=True)
with open(settings, 'w') as f: f.write(out + '\n')
PY
}

# Remove every layer hook (any command referencing multi-manager/) from settings.
remove_layer_hooks() {
    SETTINGS_PATH="$1" python3 - <<'PY'
import json, os
path = os.environ['SETTINGS_PATH']
if not os.path.exists(path):
    raise SystemExit
try:
    with open(path) as f: data = json.load(f)
except Exception:
    raise SystemExit
for blocks in data.get('hooks', {}).values():
    if isinstance(blocks, list):
        for b in blocks:
            if isinstance(b, dict) and isinstance(b.get('hooks'), list):
                b['hooks'] = [h for h in b['hooks']
                              if not (isinstance(h, dict) and 'multi-manager/' in (h.get('command', '') or ''))]
out = json.dumps(data, indent=2); json.loads(out)
with open(path, 'w') as f: f.write(out + '\n')
PY
}

# Remove settings rows whose command basename is in the (space-separated)
# retired-name list. Backs up first. Prints the count of rows removed so the
# caller can decide whether there's anything to report.
remove_retired_hook_rows() {
    SETTINGS_PATH="$1" RETIRED_NAMES="$2" python3 - <<'PY'
import json, os, shutil
path = os.environ['SETTINGS_PATH']
retired = set(os.environ['RETIRED_NAMES'].split())
if not os.path.exists(path):
    print(0); raise SystemExit
shutil.copy(path, path + '.bak')
try:
    with open(path) as f: data = json.load(f)
except Exception:
    print(0); raise SystemExit
removed = 0
for blocks in data.get('hooks', {}).values():
    if not isinstance(blocks, list): continue
    for b in blocks:
        if not isinstance(b, dict) or not isinstance(b.get('hooks'), list): continue
        kept = []
        for h in b['hooks']:
            marker = (h.get('command', '') or '').rsplit('/', 1)[-1] if isinstance(h, dict) else ''
            if isinstance(h, dict) and marker in retired:
                removed += 1
            else:
                kept.append(h)
        b['hooks'] = kept
out = json.dumps(data, indent=2); json.loads(out)
with open(path, 'w') as f: f.write(out + '\n')
print(removed)
PY
}

# Retire dead machinery left behind by a purely additive install over a
# pre-existing scope (SABLE-gsqj): retired hook files, their settings rows,
# the pre-tmux-only agents-teams dir, and retired manager agent defs in the
# scope's agents/ dir. Runs on every plain install (not just --uninstall) —
# a no-op when the scope is already clean. Prints only what it actually removed.
cleanup_retired_artifacts() {
    local -a cleaned=()

    for f in $RETIRED_HOOK_FILES; do
        if [ -e "$HOOKS_DIR/$f" ]; then
            rm -f "$HOOKS_DIR/$f"
            cleaned+=("retired hook file: $HOOKS_DIR/$f")
        fi
    done

    if [ -e "$SETTINGS" ]; then
        removed_rows="$(remove_retired_hook_rows "$SETTINGS" "$RETIRED_HOOK_FILES")"
        if [ "${removed_rows:-0}" -gt 0 ] 2>/dev/null; then
            cleaned+=("$removed_rows retired settings hook row(s) in $SETTINGS")
        fi
    fi

    if [ -e "$BASE/agents-teams" ]; then
        rm -rf "$BASE/agents-teams"
        cleaned+=("retired dir: $BASE/agents-teams")
    fi

    for f in $RETIRED_AGENT_DEFS; do
        if [ -e "$AGENTS_DIR/$f" ]; then
            rm -f "$AGENTS_DIR/$f"
            cleaned+=("retired agent def: $AGENTS_DIR/$f")
        fi
    done

    if [ "${#cleaned[@]}" -gt 0 ]; then
        echo "Retired artifacts cleaned from a prior install:"
        printf '  - %s\n' "${cleaned[@]}"
    fi
}

# Per-file change manifest + snapshot (SABLE-6lfz): every artifact below is
# copied unconditionally by design (repo source always wins), but cross-fleet
# consumers of a --user refresh (SABLE-ht22 brokered-window accounting) need
# an exact record of what actually changed. install_file diffs SRC against
# DEST before copying, records NEW/CHANGED/IDENTICAL in MANIFEST, and on
# CHANGED snapshots the prior DEST into a timestamped .bak dir under BASE.
MANIFEST=()
BAK_DIR=""

# ensure_bak_dir — assign BAK_DIR (creating the dir) in the CURRENT shell.
# Must be called directly, never via `$(...)`: command substitution runs in a
# subshell, so an assignment to BAK_DIR made there is lost once it exits,
# leaving the parent's BAK_DIR empty even though the dir was created on disk.
ensure_bak_dir() {
    if [ -z "$BAK_DIR" ]; then
        BAK_DIR="$BASE/.install-bak-$(date +%Y%m%d-%H%M%S)"
        mkdir -p "$BAK_DIR"
    fi
}

# install_file SRC DEST REL — copy SRC to DEST; REL is the path used in the
# printed manifest (relative to BASE, for readability).
install_file() {
    _src="$1" _dest="$2" _rel="$3"
    if [ ! -e "$_dest" ]; then
        cp "$_src" "$_dest"
        MANIFEST+=("NEW $_rel")
    elif cmp -s "$_src" "$_dest"; then
        MANIFEST+=("IDENTICAL $_rel")
    else
        ensure_bak_dir
        _bak="$BAK_DIR/$_rel"
        mkdir -p "$(dirname "$_bak")"
        cp "$_dest" "$_bak"
        cp "$_src" "$_dest"
        MANIFEST+=("CHANGED $_rel")
    fi
}

# --- Hook sibling-library closure (SABLE-nn54x) ---
#
# Hooks are COPY-installed, so a repo-relative sibling a hook imports resolves
# from the INSTALLED path, never the repo path. inline-body-guard.sh resolves
# its pattern logic as "$HOOK_DIR/../../bin/sable_inline_body_guard_lib.py":
# from hooks/multi-manager/ in the repo that lands on repo/bin/ and works, but
# from BASE/hooks/multi-manager/ it lands on BASE/bin/, which this installer
# never created. The copy severed the import and the hook was then WIRED,
# FIRING AND INERT — it intercepted every Bash call fleet-wide and checked
# nothing, while an installed-path presence probe, a settings.json wiring grep
# and a cmp against the landed blob all reported it ACTIVE. None of them
# inspected the DEPENDENCY CLOSURE. An activation check must verify the
# closure, not the entry point.
#
# Scope is python sibling LIBRARIES (bin/*.py) reached through a literal
# ../-prefixed reference. The two sable-* EXECUTABLES some hooks reference
# (bin/sable-mode, bin/sable-dep-check) are deliberately out of scope: both
# have a PATH-installed form via sable-bin-install and both already degrade
# to silence when absent, whereas a *.py lib has no PATH form at all — which
# is precisely why its absence was invisible.
#
# MENTION IS NOT EXECUTION, and the difference decides whether an install
# REFUSES. This scanner reads text; it does not parse shell. A hook's own
# comments routinely NAME the library they document, and a scanner that reads a
# comment as a dependency would refuse to install a hook over a stale sentence.
# So each reference carries a HARD flag:
#   hard=1  the reference appears on at least one non-comment line — a real
#           dependency. Unresolvable => REFUSE the hook.
#   hard=0  the reference appears only on comment lines — documentation. If the
#           named lib exists it is installed anyway (harmless, and correct if
#           the comment is accurate); if it does not exist the reference is
#           IGNORED. A comment can never cost the fleet a hook.
# Comment detection is deliberately the crude "first non-space char is #" rule
# rather than a half-written shell parser: it can only ever RELAX a refusal,
# never cause one, so its failure direction is safe.
#
# THE SCANNER'S BOUNDARY, documented here because this is where it is enforced
# and the person who adds a hook is reading the code, not a bead. Two reference
# shapes are deliberately NOT dependencies of the installed hook:
#
#   1. VARIABLE-COMPOSED SIBLING PATHS — LIB="${HOOK_DIR}/../../bin/${NAME}"
#      carries no literal *.py token and is NOT SEEN. This is genuine
#      under-detection, not a decision: a hook written that way would be back
#      in the wired-inert state with no warning. No shipped hook does this
#      today (see the per-hook closure table on SABLE-nn54x), so the table must
#      be re-run whenever a hook grows a new sibling reference.
#   2. $CWD-ROOTED TOOL LOOKUPS — pre-push-rebase-test.sh:612's
#      TRIPWIRE_BIN="$CWD/bin/sable-fixture-tripwire" resolves against the REPO
#      BEING PUSHED FROM, not against this hook's installed location, so no
#      amount of installing into BASE/bin would satisfy it. It is guarded by
#      [ -x "$TRIPWIRE_BIN" ] and its own comment states the no-op case ("most
#      repos this hook gates don't ship the checker"), so its absence costs a
#      skipped check, never a failure. Correctly out of scope.
#
# Both shapes are named because a reader grepping these hooks for "bin/" finds
# FOUR references and only three are in the table; the fourth's absence must
# not have to be re-derived.
#
# hook_sibling_libs HOOK_FILE INSTALLED_HOOK_DIR — print one
# "<abs-target-dir><TAB><lib-name><TAB><hard>" line per library the hook needs,
# where <abs-target-dir> is where the INSTALLED hook will actually look. Closes
# transitively: python resolves a lib's own sable_* imports from that lib's
# directory, so a one-level scan would rebuild this same defect one level down.
hook_sibling_libs() {
    HOOK_FILE="$1" HOOK_DEST_DIR="$2" REPO_DIR="$REPO" python3 - <<'PY'
import os, re

REF_RE = re.compile(r'((?:\.\./)+)bin/([A-Za-z0-9_]+\.py)')
IMPORT_RE = re.compile(r'^\s*(?:import|from)\s+(sable_[A-Za-z0-9_]+)', re.M)

repo = os.environ['REPO_DIR']
dest = os.environ['HOOK_DEST_DIR']
try:
    with open(os.environ['HOOK_FILE'], encoding='utf-8', errors='replace') as f:
        lines = f.read().splitlines()
except OSError:
    raise SystemExit(0)

# hard[(target, name)] is True once the reference is seen off a comment line.
hard, order, queue = {}, [], []


def note(target, name, is_hard):
    key = (target, name)
    if key not in hard:
        hard[key] = False
        order.append(key)
        queue.append(key)
    if is_hard and not hard[key]:
        # Upgrading to hard changes what this entry propagates, so it has to be
        # walked again -- otherwise a dep first reached through a comment stays
        # soft even after a real reference to its parent turns up.
        hard[key] = True
        queue.append(key)


for line in lines:
    is_comment = line.lstrip().startswith('#')
    for updirs, name in REF_RE.findall(line):
        note(os.path.normpath(os.path.join(dest, updirs, 'bin')), name, not is_comment)

while queue:
    target, name = queue.pop()
    try:
        with open(os.path.join(repo, 'bin', name), encoding='utf-8', errors='replace') as f:
            body = f.read()
    except OSError:
        # Unreadable here means unresolvable at install time too; the caller's
        # readability check reports it and refuses the hook when it is hard.
        continue
    for mod in IMPORT_RE.findall(body):
        dep = mod + '.py'
        if not os.path.exists(os.path.join(repo, 'bin', dep)):
            continue  # not a repo sibling (stdlib / third party) — nothing to install
        # A transitive dep is exactly as load-bearing as the parent that
        # imports it: inherit the flag rather than re-deriving it.
        note(target, dep, hard[(target, name)])

for target, name in order:
    print('%s\t%s\t%d' % (target, name, 1 if hard[(target, name)] else 0))
PY
}

# Stage (never activate) the host timer entrypoint's systemd/cron artifacts
# (SABLE-jfg6.5 / D3 TIMER LEG): sable-reconcile-timer needs NO tmux server and
# NO live panes, so it's the catch for a stranded push when the operator has
# walked away entirely (S5, the bldh.7 walk-away condition). This writes the
# unit/cron FILES into the scope's own tree via install_file (repo-source-wins,
# manifest-tracked, same as every other artifact above) but never copies them
# into ~/.config/systemd/user, never calls systemctl, and never touches a real
# crontab — live activation rides the next operator-brokered install-refresh
# window (8vlp convention). This install is repo-side only.
install_reconcile_timer() {
    local dir="$BASE/sable/reconcile-timer"
    local cadence="${SABLE_RECONCILE_INTERVAL_MIN:-15}"
    mkdir -p "$dir"

    # SABLE-5xz68 DEFECT TWO: the target repo is a PARAMETER, and it may name
    # SEVERAL repos (':'-separated) because this host runs more than one fleet.
    # A unit that sweeps one repo leaves every other fleet's stranded pushes
    # invisible to the floor while LOOKING protected — worse than no timer.
    local target_repos="${SABLE_RECONCILE_TARGET_REPO:-$REPO}"
    local repo_args="" _r
    local _oldifs="$IFS"
    IFS=':'
    for _r in $target_repos; do
        [ -n "$_r" ] || continue
        repo_args="${repo_args} --repo ${_r}"
    done
    IFS="$_oldifs"
    # strip the leading space so the generated ExecStart/cron lines are clean
    repo_args="${repo_args# }"

    local tmp
    tmp="$(mktemp -d)"

    # SABLE-7oj5: systemd --user and cron both run with a bare default PATH
    # (no shell rc, no nvm) — resolve bd's absolute path from the INSTALLING
    # shell (which has the real PATH) and bake it into the generated units so
    # sable-reconcile-handoffs's bare 'bd' call (bin/sable-reconcile-handoffs's
    # _tool("SABLE_RC_BD", "bd")) resolves regardless of the execution env.
    # Re-run install after an nvm/node version change to refresh this path.
    local bd_path bd_dir
    bd_path="$(command -v bd 2>/dev/null || true)"
    bd_dir=""
    local bd_env_line="" cron_bd_env=""
    if [ -n "$bd_path" ]; then
        bd_dir="$(dirname "$bd_path")"
        bd_env_line="Environment=SABLE_RC_BD=${bd_path}"
        cron_bd_env="SABLE_RC_BD=\"${bd_path}\" "
    else
        echo "WARNING: 'bd' not found on PATH at install time — generated" \
             "reconcile-timer units will NOT set SABLE_RC_BD and may fail" \
             "with FileNotFoundError under systemd/cron's minimal PATH." >&2
    fi
    # Fallback PATH: standard system dirs plus bd's own dir, NOT the full
    # installing shell's PATH (which drags in dev-machine cruft — plugin
    # caches, Windows /mnt/c mounts — that has no place in a service unit).
    local fallback_path="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
    [ -n "$bd_dir" ] && fallback_path="${bd_dir}:${fallback_path}"

    cat > "$tmp/sable-reconcile-timer.service" <<EOF
[Unit]
Description=SABLE reconciliation floor sweep (SABLE-jfg6.5 / D3 TIMER LEG)

[Service]
Type=oneshot
${bd_env_line}
Environment=PATH=${fallback_path}
ExecStart=%h/.local/bin/sable-reconcile-timer --once ${repo_args}
EOF

    cat > "$tmp/sable-reconcile-timer.timer" <<EOF
[Unit]
Description=Run sable-reconcile-timer on a cadence (SABLE-jfg6.5 / D3 TIMER LEG)

[Timer]
OnBootSec=5min
OnUnitActiveSec=${cadence}min
Persistent=true
Unit=sable-reconcile-timer.service

[Install]
WantedBy=timers.target
EOF

    cat > "$tmp/sable-reconcile-timer.cron" <<EOF
# SABLE reconciliation floor sweep (SABLE-jfg6.5 / D3 TIMER LEG) — cron
# fallback for hosts without systemd --user (e.g. macOS). Append to your
# crontab with: (crontab -l 2>/dev/null; cat this-file) | crontab -
*/${cadence} * * * * PATH="\$PATH:\$HOME/.local/bin:${bd_dir}" ${cron_bd_env}sable-reconcile-timer --once ${repo_args} >> "\$HOME/.cache/sable/reconcile-timer.log" 2>&1
EOF

    install_file "$tmp/sable-reconcile-timer.service" "$dir/sable-reconcile-timer.service" "sable/reconcile-timer/sable-reconcile-timer.service"
    install_file "$tmp/sable-reconcile-timer.timer"   "$dir/sable-reconcile-timer.timer"   "sable/reconcile-timer/sable-reconcile-timer.timer"
    install_file "$tmp/sable-reconcile-timer.cron"    "$dir/sable-reconcile-timer.cron"    "sable/reconcile-timer/sable-reconcile-timer.cron"
    rm -rf "$tmp"

    echo "Reconciliation timer (host-level, no tmux required) — staged, NOT activated:"
    echo "  Cadence: ${cadence}min (override next install with SABLE_RECONCILE_INTERVAL_MIN=<n>)"
    echo "  Sweeps: ${repo_args}"
    echo "    (override next install with SABLE_RECONCILE_TARGET_REPO=<repo>[:<repo>...])"
    echo "  Artifacts written under $dir/:"
    echo "    sable-reconcile-timer.service / .timer  (systemd --user; Linux)"
    echo "    sable-reconcile-timer.cron               (cron fallback line; any platform)"
    # SABLE-5xz68 DEFECT ONE: this used to echo a multi-command install recipe
    # for a human to paste, and nobody ever ran it — the units sat staged for
    # months while the floor's pane-independent leg did not exist. One command
    # now, and it VERIFIES afterwards that a schedule really fires.
    echo "  To activate — ONE command, which installs AND verifies (exit 3 if not scheduled):"
    echo "    sable-reconcile-timer --install-schedule --units-dir $dir"
    echo "  Cron fallback (hosts without systemd --user):"
    echo "    (crontab -l 2>/dev/null; cat $dir/sable-reconcile-timer.cron) | crontab -"
    echo "  Either way, confirm the floor is really scheduled:"
    echo "    sable-reconcile-timer --check-schedule ${repo_args}"
    echo "  Live activation rides the next operator-brokered install-refresh window —"
    echo "  this install only stages the artifacts (SABLE-jfg6.5 / D3, 8vlp convention)."
}

# Resolve the SABLE skill names the repo ships (by frontmatter 'name:').
skill_names() {
    for skdir in "$REPO"/skills/*/; do
        [ -f "${skdir}SKILL.md" ] || continue
        n="$(grep -m1 '^name:' "${skdir}SKILL.md" | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]\r')"
        [ -n "$n" ] || n="$(basename "$skdir")"
        printf '%s\n' "$n"
    done
}

if [ "$UNINSTALL" = "1" ]; then
    while IFS= read -r n; do rm -rf "$SKILLS/$n"; done <<EOF
$(skill_names)
EOF
    rm -f "$BASE/sable/roles/lincoln.md" "$BASE/sable/roles/optimus.md" \
          "$BASE/sable/roles/tarzan.md" "$BASE/sable/roles/chuck.md" \
          "$BASE/sable/roles/cockpit.md" "$BASE/sable/agents.yaml"
    # Sibling libraries installed for the hooks' dependency closure
    # (SABLE-nn54x). Removed FILE-BY-FILE, never as a directory: BASE/bin is a
    # shared location this installer does not own.
    for hook in "$REPO"/hooks/multi-manager/*.sh; do
        [ -f "$hook" ] || continue
        while IFS="$(printf '\t')" read -r _dir _lib _hard; do
            [ -n "${_lib:-}" ] || continue
            rm -f "$_dir/$_lib"
        done <<EOF
$(hook_sibling_libs "$hook" "$HOOKS_DIR")
EOF
    done
    # agents-teams/ is no longer installed; the rm below cleans up installs
    # that predate the tmux-only layer.
    rm -rf "$HOOKS_DIR" "$BASE/agents-teams" "$BASE/sable/reconcile-timer"
    remove_layer_hooks "$SETTINGS"
    echo "Orchestration layer uninstalled from $BASE (scope: $SCOPE)."
    echo "  (left other hooks and the settings file intact)"
    echo "  (systemd/cron activation, if any, is NOT touched here — it lives outside"
    echo "   $BASE; disable it yourself: systemctl --user disable --now sable-reconcile-timer.timer)"
    exit 0
fi

# --- Install the complete layer ---
mkdir -p "$HOOKS_DIR" "$BASE/sable/roles" "$SKILLS"

cleanup_retired_artifacts

# All multi-manager hooks (lib-identity.sh included — sourced by the others),
# each preceded by its sibling-library closure (SABLE-nn54x).
HOOK_LIB_LOG=()
REFUSED_HOOKS=()
REFUSED_HOOK_NAMES=""
for hook in "$REPO"/hooks/multi-manager/*.sh; do
    [ -f "$hook" ] || continue
    _name="$(basename "$hook")"

    _libs="$(hook_sibling_libs "$hook" "$HOOKS_DIR")"

    # Resolve the whole closure BEFORE copying anything: a hook installed
    # first and refused second would still be sitting at the installed path.
    # Only HARD references (seen off a comment line) can refuse.
    _missing=""
    while IFS="$(printf '\t')" read -r _dir _lib _hard; do
        [ -n "${_lib:-}" ] || continue
        [ "${_hard:-0}" = "1" ] || continue
        [ -r "$REPO/bin/$_lib" ] || _missing="${_missing} bin/$_lib"
    done <<EOF
$_libs
EOF

    if [ -n "$_missing" ]; then
        # An UNREGISTERED hook is strictly better than a wired inert one: a
        # gate that fires and checks nothing teaches the fleet to ignore its
        # banner, and every activation probe reports it healthy.
        REFUSED_HOOKS+=("$_name — sibling library not installable:${_missing}")
        REFUSED_HOOK_NAMES="${REFUSED_HOOK_NAMES} $_name"
        rm -f "$HOOKS_DIR/$_name"
        continue
    fi

    while IFS="$(printf '\t')" read -r _dir _lib _hard; do
        [ -n "${_lib:-}" ] || continue
        # A soft (comment-only) reference to a lib that does not exist is
        # documentation, not a dependency — install nothing, refuse nothing.
        [ -r "$REPO/bin/$_lib" ] || continue
        mkdir -p "$_dir"
        _librel="${_dir#"$BASE"/}/$_lib"
        install_file "$REPO/bin/$_lib" "$_dir/$_lib" "$_librel"
        if [ -x "$REPO/bin/$_lib" ]; then chmod +x "$_dir/$_lib" 2>/dev/null || true; fi
        if [ "${_hard:-0}" = "1" ]; then
            HOOK_LIB_LOG+=("$_name -> $_dir/$_lib")
        else
            HOOK_LIB_LOG+=("$_name -> $_dir/$_lib  (comment-only reference)")
        fi
    done <<EOF
$_libs
EOF

    install_file "$hook" "$HOOKS_DIR/$_name" "hooks/multi-manager/$_name"
    chmod +x "$HOOKS_DIR/$_name" 2>/dev/null || true
done

# Auditable per-hook record of the resolved closure — the thing no instrument
# reported when this went wrong (SABLE-nn54x).
if [ "${#HOOK_LIB_LOG[@]}" -gt 0 ]; then
    echo "Hook sibling libraries installed (dependency closure, SABLE-nn54x):"
    printf '  - %s\n' "${HOOK_LIB_LOG[@]}"
fi
if [ "${#REFUSED_HOOKS[@]}" -gt 0 ]; then
    echo "REFUSED to install these hooks — their settings registration is NOT merged" >&2
    echo "(an unregistered hook beats a wired inert one, SABLE-nn54x):" >&2
    printf '  - %s\n' "${REFUSED_HOOKS[@]}" >&2
fi

# Registry + lincoln role + identity. Remove a stale installed cockpit role
# (v2: the agent is lincoln; SABLE-uz9.5).
install_file "$REPO/templates/multi-manager/agents.yaml" "$BASE/sable/agents.yaml" "sable/agents.yaml"
# tmux warm-pane topology (SABLE-bldh): lincoln + optimus/tarzan/chuck all run as
# panes whose role session-role-anchor.sh injects from BASE/sable/roles/<name>.md
# (CLAUDE_AGENT_ROLE=manager set by sable-tmux). Install all four, not just lincoln.
for _role in lincoln optimus tarzan chuck; do
    install_file "$REPO/templates/multi-manager/roles/$_role.md" "$BASE/sable/roles/$_role.md" "sable/roles/$_role.md"
done
rm -f "$BASE/sable/roles/cockpit.md"

# SABLE skills, installed by frontmatter 'name:' (repo dir may differ).
for skdir in "$REPO"/skills/*/; do
    [ -f "${skdir}SKILL.md" ] || continue
    skname="$(grep -m1 '^name:' "${skdir}SKILL.md" | sed 's/^name:[[:space:]]*//' | tr -d '[:space:]\r')"
    [ -n "$skname" ] || skname="$(basename "$skdir")"
    mkdir -p "$SKILLS/$skname"
    for f in "${skdir}"*; do
        [ -f "$f" ] || continue
        _fname="$(basename "$f")"
        install_file "$f" "$SKILLS/$skname/$_fname" "skills/$skname/$_fname"
    done
done

# Merge the settings snippet, minus any hook this run refused. A refused hook
# may still be REGISTERED from an earlier install that did satisfy its closure
# (or from before this check existed), and its file has just been removed — so
# strip its rows too, rather than leaving settings pointing at nothing.
if [ -n "$REFUSED_HOOK_NAMES" ]; then
    remove_retired_hook_rows "$SETTINGS" "$REFUSED_HOOK_NAMES" >/dev/null || true
fi
merge_snippet "$SETTINGS" "$SNIPPET" "$SNIPPET_BASE" "$REFUSED_HOOK_NAMES"

# Stage the host timer entrypoint's systemd/cron artifacts (never activates them).
install_reconcile_timer

echo "Orchestration layer installed to $BASE (scope: $SCOPE)."
echo "  • All multi-manager hooks + agents.yaml + SABLE skills + the four pane roles installed."
echo "  • Settings snippet ($(basename "$SNIPPET")) merged into $SETTINGS (existing entries kept)."
echo "  • /sable-plan and /sable-execute become available after you restart the session."
echo "  • Start your session:  sable-launch   (Lincoln only, wraps sable-tmux; managers spawn on demand)"
echo "  • Disable anytime without uninstalling:  export SABLE_ORCHESTRATION=off"
echo "  • Max concurrent workers (default 8):  export SABLE_MAX_WORKERS=<n>"
echo "  • Uninstall:  sable-orchestration-install --$SCOPE --uninstall"
echo
echo "Change manifest ($BASE):"
_changed=0
for _entry in "${MANIFEST[@]}"; do
    _status="${_entry%% *}"
    _rel="${_entry#* }"
    printf '  %-9s %s\n' "$_status" "$_rel"
    [ "$_status" = "CHANGED" ] && _changed=$((_changed + 1))
done
if [ "$_changed" -gt 0 ] && [ -n "$BAK_DIR" ]; then
    echo "  ($_changed file(s) changed; prior copies snapshotted to $BAK_DIR)"
elif [ "$_changed" -gt 0 ]; then
    echo "  ($_changed file(s) changed)"
else
    echo "  (all files identical to source; nothing changed)"
fi
