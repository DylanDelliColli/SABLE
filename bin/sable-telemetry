#!/usr/bin/env python3
"""sable-telemetry — SABLE execution-telemetry CLI (SABLE-8b41).

Deep-module contract locked in
.claude/sable/state/planning/SABLE-8b41/architecture.json: one CLI,
`--shift [--since]` / `--trend [Nd]`, both with `--json`, hiding the source
adapters (bd/git/gh, SABLE-8b41.2/.3/.4) behind it.

--shift/--trend compose the bd (and, for --shift, git merge-event) adapters
into human-table + --json output (SABLE-8b41.8 surfacing). git/gh sources are
best-effort: an unavailable/unauthenticated `git`/`gh` degrades to zero
activity from that source rather than crashing the whole report — this tool
must keep working in environments (like the ci-verify clean room) that have
no bd/dolt at all. `--file` auto-files a --shift report as a durable
shift-telemetry ledger bead — SABLE-8b41.8's wind-down-convention fallback
while SABLE-sn20 (session-end protocol) isn't live yet; once sn20 lands, its
auto-trigger can call sable_telemetry_lib.file_shift_ledger_bead directly
instead of requiring this explicit flag.

--print-origin-labels is the taxonomy's single read path: both this CLI and
hooks/bead-description-gate.sh resolve the origin: vocabulary through it,
so the taxonomy is defined exactly once (bin/sable_telemetry_lib.py).
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))
from sable_telemetry_lib import (  # noqa: E402
    ORIGIN_LABELS,
    build_shift_report,
    build_trend_report,
    file_shift_ledger_bead,
    format_shift_report_human,
    format_trend_report_human,
    shift_report_to_dict,
    trend_report_to_dict,
)
from sable_telemetry_bd_source import fetch_bead_records  # noqa: E402
from sable_telemetry_git_source import fetch_merge_events  # noqa: E402


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(prog="sable-telemetry")
    mode = p.add_mutually_exclusive_group()
    mode.add_argument("--shift", action="store_true",
                       help="report the current shift's metrics (default action)")
    mode.add_argument("--trend", nargs="?", const="7d", default=None, metavar="Nd",
                       help="report a trend across the last Nd days (default: 7d)")
    mode.add_argument("--print-origin-labels", action="store_true",
                       help="print the origin: taxonomy labels and exit — the "
                            "single source hooks/bead-description-gate.sh reads")
    p.add_argument("--since", metavar="TIMESPEC",
                    help="restrict --shift to activity since TIMESPEC (ISO-8601, "
                         "or a bare YYYY-MM-DD date for that day's host-local "
                         "midnight); default is today (host-local)")
    p.add_argument("--json", action="store_true", help="machine-readable output")
    p.add_argument("--file", action="store_true",
                    help="auto-file the --shift report as a durable "
                         "shift-telemetry ledger bead (SABLE-8b41.8 wind-down "
                         "convention; SABLE-sn20's session-end protocol will "
                         "trigger this automatically once live)")
    return p


def _fetch_bd_records():
    try:
        return fetch_bead_records()
    except (subprocess.CalledProcessError, FileNotFoundError) as exc:
        print(f"sable-telemetry: warning: bd unavailable, reporting zero "
              f"activity ({exc})", file=sys.stderr)
        return []


def _fetch_merge_events():
    try:
        return fetch_merge_events()
    except (subprocess.CalledProcessError, FileNotFoundError) as exc:
        print(f"sable-telemetry: warning: git merge-event source unavailable "
              f"({exc})", file=sys.stderr)
        return []


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    ns = parser.parse_args(sys.argv[1:] if argv is None else argv)

    if ns.print_origin_labels:
        if ns.json:
            print(json.dumps(list(ORIGIN_LABELS)))
        else:
            for label in ORIGIN_LABELS:
                print(label)
        return 0

    if ns.file and ns.trend is not None:
        parser.error("--file is only supported with --shift (the wind-down "
                      "ledger convention)")

    if ns.trend is not None:
        records = _fetch_bd_records()
        report = build_trend_report(ns.trend, records)
        payload = trend_report_to_dict(report)
        rendered = format_trend_report_human(report)
    else:
        records = _fetch_bd_records()
        merges = _fetch_merge_events()
        report = build_shift_report(records, merges, since=ns.since)
        payload = shift_report_to_dict(report)
        rendered = format_shift_report_human(report)
        if ns.file:
            ledger_id = file_shift_ledger_bead(report)
            print(f"sable-telemetry: filed shift-telemetry ledger bead {ledger_id}",
                  file=sys.stderr)

    if ns.json:
        print(json.dumps(payload, indent=2))
    else:
        print(rendered)
    return 0


if __name__ == "__main__":
    sys.exit(main())
