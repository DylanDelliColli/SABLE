#!/usr/bin/env bash
# sable — the umbrella command (SABLE-ssws.4). `sable --help` is the operator
# map; `sable <sub> ...` dispatches to the sable-<sub> sibling tool; `sable
# help <sub>` shows that tool's usage.

set -u

# Resolve siblings next to the REAL script (works via the ~/.local/bin symlink).
SELF="${BASH_SOURCE[0]}"
[ -L "$SELF" ] && SELF="$(readlink -f "$SELF" 2>/dev/null || echo "$SELF")"
BIN_DIR="${SELF%/*}"

subcommands() {
  local f
  for f in "$BIN_DIR"/sable-*; do
    [ -f "$f" ] && [ -x "$f" ] || continue
    case "$f" in *.py|*.bak|*~) continue ;; esac
    printf '%s\n' "${f##*/sable-}"
  done
}

operator_map() {
  cat <<'EOF'
sable — the SABLE operator map

START HERE
  sable-launch              start (or re-attach) YOUR session: a tmux session
                            holding only the lincoln pane — the agent you talk
                            to. Mode-neutral: plan or execute from here.
                            Managers appear later, in their own hidden windows
                            (sable-spawn-manager, driven by /sable-execute).
  sable-view                deep-dive into the agent panes — best from a
                            SECOND terminal (grouped session: your Lincoln
                            view is never stolen):
                              sable-view                 status table
                              sable-view <role>          focus that pane
                              sable-view <role> --tail   read it without switching

TMUX KEYS (inside a sable-view deep-dive)
  Ctrl-b d                  LEAVE: detach the viewer. Only the throwaway view
                            session dies — the agent pane and its claude
                            process keep running. Never type Ctrl-c / Ctrl-d /
                            exit instead: those go to the REAL pane and kill
                            the agent you are watching.
  Ctrl-b w                  switch agents: window tree with live previews
                            (each agent lives in its OWN window, so pane
                            rotation Ctrl-b o does nothing here)
  Ctrl-b n / p / l          next / previous / last window
  see several at once       one terminal pane per role, each running
                            `sable-view <role>` — or read-only:
                            `watch -n 2 -t "sable-view <role> --tail"`

WORK DOORS (type these to Lincoln, in its pane)
  /sable-discover           decide WHAT to build — triage candidates, emit charters
  /sable-plan               fill the backlog — Quick or Full (five gated substages)
  /sable-execute            drain the backlog — managers dispatch worker panes,
                            workers self-push, Chuck merges

TOOLBOX (each also runs as `sable <name> ...`, e.g. `sable msg ...`)
  sable-spawn-manager <role>|--all  stand up manager windows (execution mode)
  sable-msg <role> "<text>"      message a pane (--interrupt to land mid-turn)
  sable-worker-status [--reap]   list / reap worker panes
  sable-mode                     read or flip the planning|execution mode state
  sable-contract add|set|clear   write live protocol contracts surfaced at boot
  sable-note "<text>"            capture a SABLE methodology observation
  sable-agents [name]            who does what (roster reminder)
  sable-charter                  charter/decision artifacts (Discovery outputs)
  sable-tmux                     low-level session layout (sable-launch wraps it)

DOCS
  QUICKSTART.md             install + first session, in ~10 minutes
  TMUX-AGENTS-DESIGN.md     the warm-pane topology (canonical design)
  MULTI-MANAGER-PATTERN.md  the full coordination pattern, hooks, discipline

Any subcommand: sable <name> --help   (or: sable help <name>)
EOF
}

case "${1:-}" in
  ""|-h|--help)
    operator_map
    exit 0 ;;
  help)
    if [ -n "${2:-}" ]; then
      TOOL="$BIN_DIR/sable-$2"
      [ -x "$TOOL" ] || { printf 'sable: no such subcommand: %s\n' "$2" >&2; exit 2; }
      exec "$TOOL" --help
    fi
    operator_map
    exit 0 ;;
  *)
    SUB="$1"; shift
    TOOL="$BIN_DIR/sable-$SUB"
    if [ ! -x "$TOOL" ]; then
      printf 'sable: unknown subcommand %s\navailable: %s\n' \
        "$SUB" "$(subcommands | tr '\n' ' ')" >&2
      exit 2
    fi
    exec "$TOOL" "$@" ;;
esac
