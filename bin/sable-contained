#!/usr/bin/env python3
"""sable-contained — the containment check, with the argument order hardcoded
(SABLE-gdp05).

THE DEFECT THIS EXISTS FOR
--------------------------
SABLE-4344d prescribes `git merge-base --is-ancestor <sha> origin/<integration>`
as THE containment check between serialized dispatches: "has <sha> landed on
the integration branch". Both argument orders are valid git and both exit
0/1 — nothing warns when they are swapped. Live incident, 2026-07-21 (optimus):
the inverted form ("--is-ancestor origin/tmux-only <sha>") asks the OPPOSITE
question ("is origin's tip an ancestor of <sha>"), returned false, and was
read as "the work was lost" when it had in fact merged cleanly.

The inversion has TWO directions and they are not equally dangerous:
  - <sha> old, integration advanced since it merged -> inverted form says
    NOT-CONTAINED for something that IS contained. A FALSE ALARM: harmless,
    costs time (this is what hit optimus).
  - <sha> is an unmerged branch freshly forked from the integration tip ->
    inverted form says CONTAINED for something that is NOT. A FALSE GREEN: a
    manager serializing dispatches into the same module gets a spurious
    "go ahead" and dispatches into a live collision. This is the SABLE-5lli
    class danger and the reason this wrapper exists rather than a comment.

THE FIX: hardcode the order at the interface. This tool takes EXACTLY ONE
positional argument (<sha>) and derives the integration branch itself
(bin/sable_gate_git_lib.resolve_integration_branch — the same resolver the
merge gate and pre-push hook use), so there is no second positional an
inverted invocation could occupy: the bug is unrepresentable, not just
discouraged.

THE SECOND DEFECT: PATH MODE (SABLE-4snb4)
------------------------------------------
The sibling footgun, hit live 2026-07-22 (optimus). The other containment
question the fleet asks constantly is "is this FILE on the spine yet" — the
PROPERTY probe (does the mechanism exist in the tree?) that the
reference-by-property rule prefers over a SHA probe. The natural-looking
idiom for it is silently wrong:

    git ls-tree <ref> <path> --name-only && echo "PRESENT"   # WRONG

`git ls-tree` EXITS 0 FOR AN ABSENT PATH — it just prints nothing. So that
probe prints PRESENT for a file that is not in the ref, and — exactly like
the merge-base inversion above — the failure is in the HOLD-RELEASING
direction. Live: probing hooks/test/test-impact-tier-serialization.sh (new
in SABLE-jd5fj.13's footprint) reported ON SPINE while .13 was in fact
unmerged; had it been trusted, SABLE-cmar4.5 would have been dispatched onto
a base lacking .13, into the very seat collision the sequencing exists to
prevent. Caught only because three corroborating signals disagreed.

Path mode wraps the CORRECT primitives, again in two independent legs:
`git cat-file -e <ref>:<path>` (whose exit status DOES track presence) and
`git ls-tree <ref> -- <path>` judged on its OUTPUT being non-empty, never on
its exit status. Same verdict vocabulary and same exit codes as commit mode,
so a caller never has to remember which containment question it asked.

CROSS-CHECK: every call also runs a SECOND, independent method
(`git log <integration>..<sha>` — non-empty means <sha> carries commits the
integration branch doesn't have, i.e. NOT contained) and compares it against
`merge-base --is-ancestor`. The two ask the containment question through
different git plumbing; a real git repository can never make them disagree.
If they do disagree here, that means one of the two invocations was built
wrong (or something is scribbling on the environment), so the tool refuses to
answer CONTAINED/NOT-CONTAINED at all and says so loudly instead.

USAGE
  COMMIT MODE — has <sha> landed?
  sable-contained <sha>                             # CONTAINED / NOT-CONTAINED
  sable-contained <sha> --repo <path>                # a git repo other than CWD
  sable-contained <sha> --integration-branch <name>  # override auto-resolution
  sable-contained <sha> --format=json                # machine-readable

  PATH MODE — is <path> in the tree of <ref>?
  sable-contained --path <path>                      # against the integration ref
  sable-contained --path <path> --ref <ref>          # against any ref

  The two modes are mutually exclusive: a <sha> positional is the commit
  question, --path is the path question, and asking both at once is a usage
  error rather than a silent precedence rule.

EXIT CODES (identical in both modes — one vocabulary for containment)
  0  CONTAINED     — <sha> is merged into the integration branch / <path>
                     exists in <ref>'s tree.
  1  NOT-CONTAINED — <sha> is NOT merged / <path> is NOT in <ref>'s tree.
  2  usage error
  3  DISAGREEMENT  — the two methods gave different answers; treat as
                     unresolved and verify by hand.
  4  COULD NOT ASSESS — the integration branch/ref does not resolve, or both
                     methods errored (bad ref, git failure).
"""
from __future__ import annotations

import argparse
import json
import os
import subprocess
import sys

sys.path.insert(0, os.path.dirname(os.path.realpath(__file__)))

import sable_gate_git_lib as git_lib  # noqa: E402

EXIT_CONTAINED = 0
EXIT_NOT_CONTAINED = 1
EXIT_USAGE = 2
EXIT_DISAGREE = 3
EXIT_UNRESOLVED = 4

CONTAINED = "contained"
NOT_CONTAINED = "not-contained"
UNRESOLVED = "unresolved"
DISAGREE = "disagree"


# --- pure-ish helpers (unit-tested in bin/test_sable_contained.py) ----------

def is_ancestor_verdict(rc: int) -> str:
    """`git merge-base --is-ancestor <sha> <base>` exit code -> verdict.
    0 = <sha> IS an ancestor of <base> (contained); 1 = it is NOT
    (not-contained); anything else (bad ref, git failure) is UNRESOLVED and
    must never be guessed at as either verdict."""
    if rc == 0:
        return CONTAINED
    if rc == 1:
        return NOT_CONTAINED
    return UNRESOLVED


def log_range_verdict(rc: int, stdout: str) -> str:
    """`git log <base>..<sha>` -> verdict. A non-zero exit (bad ref) is
    UNRESOLVED. Otherwise: an EMPTY range means every commit reachable from
    <sha> is already reachable from <base> — contained. Any listed commit is
    one <base> does not have — not contained."""
    if rc != 0:
        return UNRESOLVED
    return CONTAINED if not stdout.strip() else NOT_CONTAINED


def combine_verdicts(verdict_a: str, verdict_b: str) -> tuple[str, bool]:
    """Reconcile the two independent methods into one answer plus an `agree`
    flag. Both resolved and matching -> that verdict. Both resolved and
    DIFFERENT -> DISAGREE (the cross-check firing) regardless of which side
    said what. Anything else (either side UNRESOLVED) -> UNRESOLVED — a
    single working method is not enough to answer on its own, since the
    entire point of the second leg is that neither is trusted alone."""
    agree = verdict_a == verdict_b
    if agree and verdict_a != UNRESOLVED:
        return verdict_a, True
    if not agree and UNRESOLVED not in (verdict_a, verdict_b):
        return DISAGREE, False
    return UNRESOLVED, agree


def cat_file_verdict(rc: int) -> str:
    """`git cat-file -e <ref>:<path>` exit code -> verdict. UNLIKE ls-tree,
    this command's exit status actually tracks presence: 0 = the object
    resolves (the path IS in that ref's tree), non-zero = it does not. git
    does not distinguish "absent path" from "bad ref" in this exit code,
    which is why main() resolves the ref FIRST — by the time this runs, a
    non-zero can only mean the path is absent."""
    return CONTAINED if rc == 0 else NOT_CONTAINED


def ls_tree_verdict(rc: int, stdout: str) -> str:
    """`git ls-tree <ref> -- <path>` -> verdict, judged on OUTPUT.

    THIS IS THE DEFECT OF SABLE-4snb4, inverted into a correct probe. ls-tree
    exits 0 for an ABSENT path and simply prints nothing, so `ls-tree ... &&
    echo PRESENT` is a false POSITIVE generator — the hold-RELEASING
    direction. The output, unlike the exit status, does track presence: one
    line per matching tree entry, empty when there is no such path. A
    non-zero rc (unresolvable ref) is UNRESOLVED, never a verdict."""
    if rc != 0:
        return UNRESOLVED
    return CONTAINED if stdout.strip() else NOT_CONTAINED


def render_report(sha: str, integration_ref: str, result: dict) -> str:
    """The one-line human/hook answer. Every non-clean path names both
    methods' verdicts so a reader never has to re-run the tool to see why."""
    verdict = result["verdict"]
    if verdict == CONTAINED:
        return f"CONTAINED: {sha} is merged into {integration_ref}"
    if verdict == NOT_CONTAINED:
        return f"NOT-CONTAINED: {sha} is NOT merged into {integration_ref}"
    if verdict == DISAGREE:
        return (
            f"DISAGREEMENT (SABLE-gdp05): containment of {sha} against "
            f"{integration_ref} is UNRESOLVED — the two independent methods "
            f"disagree (merge-base says {result['method_a']}, log-range says "
            f"{result['method_b']}). Do not trust either; verify by hand."
        )
    return (
        f"COULD NOT ASSESS: containment of {sha} against {integration_ref} "
        f"could not be determined (merge-base={result['method_a']}, "
        f"log-range={result['method_b']})"
    )


def render_path_report(path: str, ref: str, result: dict) -> str:
    """Path mode's one-line answer. Same four shapes and the same leading
    words as render_report, so a reader (or a grep in a role card) does not
    have to know which question was asked to read the verdict."""
    verdict = result["verdict"]
    if verdict == CONTAINED:
        return f"CONTAINED: {path} is present in {ref}"
    if verdict == NOT_CONTAINED:
        return f"NOT-CONTAINED: {path} is NOT present in {ref}"
    if verdict == DISAGREE:
        return (
            f"DISAGREEMENT (SABLE-4snb4): presence of {path} in {ref} is "
            f"UNRESOLVED — the two independent methods disagree (cat-file "
            f"says {result['method_a']}, ls-tree output says "
            f"{result['method_b']}). Do not trust either; verify by hand."
        )
    return (
        f"COULD NOT ASSESS: presence of {path} in {ref} could not be "
        f"determined (cat-file={result['method_a']}, "
        f"ls-tree={result['method_b']})"
    )


# --- process boundary --------------------------------------------------------

def _git(repo: str, *args: str) -> subprocess.CompletedProcess:
    """Never raises: a missing/misconfigured git is COULD-NOT-ASSESS here,
    not a traceback. The tool binary is overridable via SABLE_CONTAINED_GIT
    (mirrors sable_gate_git_lib's own SABLE_MG_GIT seam) so tests can inject
    a faulty git and prove the cross-check actually fires — real git can
    never disagree with itself, so seeding a fault is the only way to
    exercise that leg at all."""
    tool = os.environ.get("SABLE_CONTAINED_GIT", "git").split()
    try:
        return subprocess.run(tool + list(args), cwd=repo, text=True,
                               capture_output=True)
    except OSError as exc:
        return subprocess.CompletedProcess(list(args), 127, "", str(exc))


def resolve_integration_ref(repo: str, branch: str) -> str:
    """The ref to judge ancestry against: prefer the PUBLISHED
    origin/<branch> (what every worker/manager actually lands onto); fall
    back to the local refs/heads/<branch> when the integration branch is not
    (yet) published. "" when neither resolves."""
    for ref in (f"origin/{branch}", branch):
        cp = _git(repo, "rev-parse", "--verify", "--quiet", ref)
        if cp.returncode == 0:
            return ref
    return ""


def containment_verdict(repo: str, sha: str, integration_ref: str) -> dict:
    """Runs BOTH independent methods and reconciles them. Returns
    {verdict, method_a, method_b, agree}."""
    a = _git(repo, "merge-base", "--is-ancestor", sha, integration_ref)
    method_a = is_ancestor_verdict(a.returncode)

    b = _git(repo, "log", f"{integration_ref}..{sha}")
    method_b = log_range_verdict(b.returncode, b.stdout)

    verdict, agree = combine_verdicts(method_a, method_b)
    return {"verdict": verdict, "method_a": method_a, "method_b": method_b,
            "agree": agree}


def ref_resolves(repo: str, ref: str) -> bool:
    """Does <ref> name something this repo can resolve? Path mode checks this
    BEFORE probing, because `git cat-file -e <ref>:<path>` returns the same
    non-zero for "no such ref" as for "no such path" — without this gate a
    typo'd ref would report a confident NOT-CONTAINED instead of COULD NOT
    ASSESS, and only one of those is safe to act on."""
    return _git(repo, "rev-parse", "--verify", "--quiet", f"{ref}^{{commit}}").returncode == 0


def path_containment_verdict(repo: str, ref: str, path: str) -> dict:
    """Runs BOTH independent path-presence methods and reconciles them, in
    the same shape commit mode returns. Callers must have established that
    <ref> resolves (see ref_resolves)."""
    a = _git(repo, "cat-file", "-e", f"{ref}:{path}")
    method_a = cat_file_verdict(a.returncode)

    b = _git(repo, "ls-tree", "--name-only", ref, "--", path)
    method_b = ls_tree_verdict(b.returncode, b.stdout)

    verdict, agree = combine_verdicts(method_a, method_b)
    return {"verdict": verdict, "method_a": method_a, "method_b": method_b,
            "agree": agree}


# --- CLI ---------------------------------------------------------------------

def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(
        prog="sable-contained",
        description="Is <sha> contained in this repo's integration branch, or "
                     "is --path present in --ref? Hardcodes the merge-base "
                     "--is-ancestor argument order so the inversion behind "
                     "SABLE-gdp05 cannot be expressed, and never judges path "
                     "presence by ls-tree's exit status (SABLE-4snb4).",
    )
    parser.add_argument("sha", nargs="?", default=None,
                         help="commit-ish to test for containment (commit mode)")
    parser.add_argument("--path", default=None,
                         help="repo-relative path to test for presence in a "
                              "ref's tree (path mode)")
    parser.add_argument("--ref", default=None,
                         help="ref whose tree --path is looked up in "
                              "(default: the integration ref)")
    parser.add_argument("--repo", default=os.getcwd(),
                         help="git repo to check (default: CWD)")
    parser.add_argument("--integration-branch", default=None,
                         help="override the auto-resolved integration branch "
                              "(default: resolve_integration_branch, same as "
                              "the merge gate / pre-push hook)")
    parser.add_argument("--format", choices=["text", "json"], default="text")
    return parser


def _emit(payload: dict, message: str, fmt: str) -> None:
    print(json.dumps({**payload, "message": message}) if fmt == "json" else message)


def _exit_for(verdict: str) -> int:
    return {
        CONTAINED: EXIT_CONTAINED,
        NOT_CONTAINED: EXIT_NOT_CONTAINED,
        DISAGREE: EXIT_DISAGREE,
    }.get(verdict, EXIT_UNRESOLVED)


def _run_path_mode(args, repo: str, integration_ref: str, branch: str) -> int:
    """--path: is that path in <ref>'s tree? --ref defaults to the integration
    ref, since "is this file on the spine yet" is the question that motivated
    the mode."""
    ref = args.ref or integration_ref
    payload = {"mode": "path", "path": args.path, "ref": ref,
                "integration_branch": branch}

    if not ref or not ref_resolves(repo, ref):
        named = ref or f"(integration branch '{branch}' did not resolve)"
        message = (f"COULD NOT ASSESS: ref {named} does not resolve in {repo}, "
                    f"so the presence of {args.path} is unknown")
        _emit({**payload, "ref": ref or None, "verdict": UNRESOLVED,
               "method_a": UNRESOLVED, "method_b": UNRESOLVED, "agree": False},
              message, args.format)
        return EXIT_UNRESOLVED

    result = path_containment_verdict(repo, ref, args.path)
    _emit({**payload, **result},
          render_path_report(args.path, ref, result), args.format)
    return _exit_for(result["verdict"])


def _run_commit_mode(args, repo: str, integration_ref: str, branch: str) -> int:
    if not integration_ref:
        message = (f"COULD NOT ASSESS: integration branch '{branch}' does not "
                   f"resolve (checked origin/{branch} and {branch}) in {repo}")
        _emit({"mode": "commit", "sha": args.sha, "integration_branch": branch,
               "integration_ref": None, "verdict": UNRESOLVED,
               "method_a": UNRESOLVED, "method_b": UNRESOLVED, "agree": False},
              message, args.format)
        return EXIT_UNRESOLVED

    result = containment_verdict(repo, args.sha, integration_ref)
    _emit({"mode": "commit", "sha": args.sha, "integration_branch": branch,
           "integration_ref": integration_ref, **result},
          render_report(args.sha, integration_ref, result), args.format)
    return _exit_for(result["verdict"])


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)

    # Mode selection is explicit and fails closed: no silent precedence
    # between the two containment questions, and no defaulting to one when
    # the caller named neither.
    if args.sha and args.path:
        parser.error("give a <sha> (commit containment) or --path (path "
                      "presence), not both — they are different questions")
    if not args.sha and not args.path:
        parser.error("nothing to check: pass a <sha> for commit containment "
                      "or --path for path presence")
    if args.ref and not args.path:
        parser.error("--ref applies to --path only; commit mode derives the "
                      "integration ref itself so the argument order cannot be "
                      "inverted (SABLE-gdp05)")

    repo = os.path.abspath(args.repo)
    branch = args.integration_branch or git_lib.resolve_integration_branch(repo)
    integration_ref = resolve_integration_ref(repo, branch)

    if args.path:
        return _run_path_mode(args, repo, integration_ref, branch)
    return _run_commit_mode(args, repo, integration_ref, branch)


if __name__ == "__main__":
    sys.exit(main())
