#!/usr/bin/env python3
"""sable-build-agents — generate custom agent definitions from SABLE role files.

The role files under templates/multi-manager/roles/ remain the single source of
truth (legacy env-var launches and Chuck's terminal still read them). This
script wraps each converted role in agent-definition frontmatter and a v2
invocation preamble, writing templates/agents/<name>.md.

Edit the ROLE FILE and re-run this script; never hand-edit the generated files.
hooks/test/test-agent-definitions.sh asserts generated == committed.

Usage:
  sable-build-agents [--out-dir DIR]   # default: <repo>/templates/agents
"""

import sys
from pathlib import Path

REPO = Path(__file__).resolve().parent.parent
ROLES = REPO / "templates" / "multi-manager" / "roles"
DEFAULT_OUT = REPO / "templates" / "agents"

# Agents converted to subagent definitions in SABLE v2.
# Deliberately absent: chuck (env-var terminal holdout, SABLE-uz9.6),
# optimus/tarzan (land behind the identity ledger, SABLE-uz9.4),
# cockpit/lincoln (main-session role, not a subagent, SABLE-uz9.5),
# gaudi (skill, not a role file — open question on SABLE-uz9.2).
AGENTS = {
    "sherlock": (
        "Read-only repo auditor producing exceptional finding beads — design rot, "
        "redundancy, verbosity, dead code, test gaps — or greenfield research findings "
        "(RESEARCH substage). Use during planning to audit a scope or de-risk a design. "
        "Writes beads only, never code."
    ),
    "victor": (
        "Bead-pool freshness validator. Validates open beads against current HEAD via "
        "fingerprint greps and verify commands, flags or (post ramp-up) closes stale ones, "
        "updates drifted evidence. Use before dispatch waves or for periodic backlog "
        "hygiene. Read-only with respect to source."
    ),
    "rudy": (
        "End-to-end browser validator for the integration-branch dev deploy (Vercel "
        "preview + Supabase dev only — refuses production, PR-preview, and local-dev "
        "targets). Clicks through user flows, captures repro evidence, files bug beads "
        "plus a rudy-report."
    ),
    "columbo": (
        "Interview-driven test-coverage planner. Forward mode produces test-spec beads + "
        "skeleton test files; audit mode files test-gap beads against existing modules; "
        "epic mode gates the test architecture of a planned bead tree before execution. "
        "Read-only with respect to source."
    ),
}

PREAMBLE = """\
> **v2 invocation (one-window topology).** You are spawned as a named subagent
> by the Lincoln main session (or directly by the user from the main
> conversation). Your scope/mode arrives in the spawn prompt rather than a
> shell argument — read the legacy shell invocations below (e.g.
> `{name} <scope>`) as prompt parameters (e.g. "scope: <scope>"). Your identity
> comes from this agent definition's system prompt, not CLAUDE_AGENT_NAME; the
> continuous-mode manager hooks never applied to you and still don't. One
> capability difference: in subagent context you have NO Agent tool — where this
> role says to dispatch read-only Explore subagents, do that exploration
> yourself with Read/Glob/Grep/Bash instead (verified CC 2.1.170, SABLE-uz9.1).
> Everything else in this role is unchanged and binding. Deliver your
> end-of-session summary as your final message back to the spawning session.
"""


def build(out_dir: Path) -> int:
    out_dir.mkdir(parents=True, exist_ok=True)
    for name, description in AGENTS.items():
        role = ROLES / f"{name}.md"
        if not role.exists():
            print(f"ERROR: missing role file {role}", file=sys.stderr)
            return 1
        body = role.read_text()
        generated = (
            "---\n"
            f"name: {name}\n"
            f"description: {description}\n"
            "---\n"
            f"<!-- GENERATED from templates/multi-manager/roles/{name}.md by "
            "bin/sable-build-agents — edit the role file and re-run; do not hand-edit. -->\n\n"
            f"{PREAMBLE.format(name=name)}\n"
            f"{body}"
        )
        target = out_dir / f"{name}.md"
        target.write_text(generated)
        print(f"wrote {target}")
    return 0


if __name__ == "__main__":
    out = DEFAULT_OUT
    args = sys.argv[1:]
    if len(args) == 2 and args[0] == "--out-dir":
        out = Path(args[1])
    elif args:
        print(__doc__, file=sys.stderr)
        sys.exit(2)
    sys.exit(build(out))
