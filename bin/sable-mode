#!/usr/bin/env bash
# sable-mode — read/write the orchestration mode-state file.
#
# Single source of truth for which mode the orchestration session is in. Written by
# the /plan and /execute skills; read by the mode interlock hook
# (mode-interlock.sh). Uses python3 for
# JSON (always present — it defines the env); deliberately NO jq dependency,
# which is fragile across conda envs (see SABLE-cav.8).
#
# State file — resolved PER-REPO by resolve_state_path (mirrors
# hooks/multi-manager/lib-mode-path.sh): inside a git repo it is the repo's
# main-worktree .claude/sable/state/mode-state.json (shared across the repo's
# worktrees), so independent SABLE sessions in different repos keep independent
# modes; outside a git repo it falls back to ~/.claude/sable/state/mode-state.json.
# Override the location with SABLE_MODE_STATE (testing + manual escape hatch).
#   ~/.claude/sable/state/mode-state.json
# Shape:
#   { "mode": "planning|execution", "since": "<ISO-8601>", "fleet": ["a","b"],
#     "substage": "framing|research|architecture|test-strategy|decomposition" }
#   substage is present only in planning mode (entering planning starts at
#   framing). It is the gated sub-state machine the /plan flow walks and the
#   interlock reads to block backlog authoring before decomposition.
#
# Runtime enable gate: when SABLE_ORCHESTRATION is off/0/false/no (case-insensitive),
# `set` refuses (so /plan and /execute cannot flip mode); `get`/`show` still
# read. Unset (or any other value) = enabled.
#
# Usage:
#   sable-mode set <planning|execution> [--fleet a,b,c]
#   sable-mode get                 # print the bare mode word (nonzero if unset);
#                                  # warns on stderr if the state is stale
#   sable-mode show                # print the full JSON (nonzero if unset)
#   sable-mode clear                # delete the mode-state file
#   sable-mode substage get        # print the planning substage (nonzero if none)
#   sable-mode substage set <name> # set substage to a named stage
#   sable-mode substage advance    # move to the next substage (nonzero past end)
#   sable-mode --help

set -eu

# resolve_state_path [base_dir] — MIRROR of sable_mode_state_path in
# hooks/multi-manager/lib-mode-path.sh. Kept as a copy (not a source) because
# post-install there is no stable path from this binary (~/.local/bin symlink)
# to the hooks dir (~/.claude/hooks copy); a drift-guard test in
# test-sable-mode.sh asserts the two implementations stay identical.
resolve_state_path() {
    if [ -n "${SABLE_MODE_STATE:-}" ]; then
        printf '%s\n' "$SABLE_MODE_STATE"
        return 0
    fi
    local base="${1:-$PWD}"
    local common root
    if common="$(git -C "$base" rev-parse --git-common-dir 2>/dev/null)" && [ -n "$common" ]; then
        case "$common" in
            /*) ;;
            *)  common="$base/$common" ;;
        esac
        if root="$(cd "$(dirname "$common")" 2>/dev/null && pwd)" && [ -n "$root" ]; then
            printf '%s\n' "$root/.claude/sable/state/mode-state.json"
            return 0
        fi
    fi
    printf '%s\n' "${HOME:-}/.claude/sable/state/mode-state.json"
}

# ensure_state_gitignored <state-path> — best-effort: when the state file lives
# inside a git repo at the canonical <root>/.claude/sable/state/ location, make
# sure that path is gitignored so the ephemeral mode-state never shows up as
# untracked in an adopter's repo (any install tier). Idempotent; respects a
# pre-existing broader '.claude/sable/' ignore; silent on any failure. Skips
# override / non-git paths (they don't match the canonical suffix).
ensure_state_gitignored() {
    local state="$1" root gi pattern=".claude/sable/state/"
    case "$state" in
        */.claude/sable/state/mode-state.json)
            root="${state%/.claude/sable/state/mode-state.json}" ;;
        *) return 0 ;;
    esac
    git -C "$root" rev-parse --is-inside-work-tree >/dev/null 2>&1 || return 0
    gi="$root/.gitignore"
    if [ -f "$gi" ] && grep -q '\.claude/sable/' "$gi" 2>/dev/null; then
        return 0
    fi
    printf '%s\n' "$pattern" >> "$gi" 2>/dev/null || true
}

STATE="$(resolve_state_path)"

# Staleness threshold (hours) for the 'get' warning below — overridable for
# tests. A mode-state older than this almost certainly outlived the session
# that wrote it (SABLE-rucp: a discovery-tier state from 2026-06-26 was still
# being read as live 12 days later with a clean tree and no active run).
STALE_HOURS="${SABLE_MODE_STALE_HOURS:-72}"

# warn_if_stale <state-path> — best-effort stderr warning when the state's
# 'since' timestamp is older than STALE_HOURS. Advisory only: never affects
# exit code or stdout, silent on any parse error.
warn_if_stale() {
    STATE="$1" STALE_HOURS="$STALE_HOURS" python3 -c "
import json, os, sys
from datetime import datetime, timezone
try:
    d = json.load(open(os.environ['STATE']))
    since = d.get('since') or ''
    if not since:
        sys.exit(0)
    ts = datetime.strptime(since, '%Y-%m-%dT%H:%M:%S%z')
    age_hours = (datetime.now(timezone.utc) - ts).total_seconds() / 3600.0
    if age_hours > float(os.environ['STALE_HOURS']):
        print(
            \"sable-mode: WARNING - mode-state is stale (%.1fd old, mode=%s, since %s) - if this session has ended, run 'sable-mode clear'\"
            % (age_hours / 24.0, d.get('mode', '') or '?', since),
            file=sys.stderr,
        )
except Exception:
    pass
"
}

usage() {
    cat <<EOF
sable-mode — read/write the orchestration mode-state file.

Usage:
  sable-mode set <planning|execution> [--fleet a,b,c] [--tier quick|full|discovery]
      Write the mode-state file. --fleet is a comma-separated list of the
      agents launched for this mode (recorded for the dashboard). --tier sets
      the planning tier (default full); quick telescopes the backlog gate, and
      discovery (Mode 1) is the lightest sub-mode — no backlog gate, since
      Discovery authors no implementation beads (it writes charters).
  sable-mode get      Print the current mode word; nonzero exit if unset. Warns
                      on stderr (SABLE_MODE_STALE_HOURS, default 72) when the
                      state is older than that and suggests 'sable-mode clear'.
  sable-mode show     Print the full mode-state JSON; nonzero exit if unset.
  sable-mode path     Print the resolved mode-state file path (no state needed).
  sable-mode clear    Delete the mode-state file; nonzero exit if none exists.
  sable-mode substage get        Print the current planning substage; nonzero
                                 if unset or not in planning mode.
  sable-mode substage set <name> Set the substage to one of:
                                 framing research architecture test-strategy decomposition
  sable-mode substage advance    Advance to the next substage in order; nonzero
                                 if already at decomposition.
  sable-mode tier get            Print the planning tier (quick|full|discovery,
                                 default full); nonzero if unset or not in planning.
  sable-mode --help

State file (resolved per-repo): ${STATE}
  Inside a git repo this is <repo>/.claude/sable/state/mode-state.json (shared
  across the repo's worktrees); otherwise ~/.claude/sable/state/mode-state.json.
  Override the location with the SABLE_MODE_STATE environment variable.

Disable at runtime with: SABLE_ORCHESTRATION=off
EOF
}

# Runtime enable gate. Disabled when SABLE_ORCHESTRATION is off/0/false/no.
orchestration_enabled() {
    case "$(printf '%s' "${SABLE_ORCHESTRATION:-}" | tr '[:upper:]' '[:lower:]')" in
        off|0|false|no) return 1 ;;
        *) return 0 ;;
    esac
}

require_state() {
    if [ ! -f "$STATE" ]; then
        printf 'sable-mode: no mode set (no state file at %s)\n' "$STATE" >&2
        exit 1
    fi
}

cmd="${1:-}"
case "$cmd" in
    -h|--help)
        usage
        exit 0
        ;;
    get)
        require_state
        warn_if_stale "$STATE"
        STATE="$STATE" python3 -c "import json,os; print(json.load(open(os.environ['STATE'])).get('mode','') or '')"
        ;;
    show)
        require_state
        cat "$STATE"
        ;;
    path)
        # Print the resolved state-file path. No state required — answers
        # "where would the mode-state for this repo live?" even when unset.
        printf '%s\n' "$STATE"
        ;;
    clear)
        # Remove the mode-state file — the remedy the 'get' staleness warning
        # suggests (SABLE-rucp). Idempotent-ish: nonzero + stderr message if
        # there was nothing to clear, mirroring require_state's own message.
        if [ -f "$STATE" ]; then
            rm -f "$STATE"
            printf 'sable-mode: cleared mode-state at %s\n' "$STATE"
        else
            printf 'sable-mode: no mode set (no state file at %s)\n' "$STATE" >&2
            exit 1
        fi
        ;;
    set)
        if ! orchestration_enabled; then
            printf 'sable-mode: orchestration disabled (SABLE_ORCHESTRATION=%s); unset SABLE_ORCHESTRATION to enable\n' "${SABLE_ORCHESTRATION:-}" >&2
            exit 3
        fi
        mode="${2:-}"
        case "$mode" in
            planning|execution) ;;
            *)
                printf "sable-mode: invalid mode '%s' (must be planning or execution)\n" "$mode" >&2
                exit 2
                ;;
        esac

        # Consume the verb + mode, then scan for --fleet and --tier.
        shift 2 || true
        fleet_csv=""
        tier=""
        while [ $# -gt 0 ]; do
            case "$1" in
                --fleet)    fleet_csv="${2:-}"; shift 2 || shift ;;
                --fleet=*)  fleet_csv="${1#--fleet=}"; shift ;;
                --tier)     tier="${2:-}"; shift 2 || shift ;;
                --tier=*)   tier="${1#--tier=}"; shift ;;
                *)          shift ;;
            esac
        done
        case "${tier:-full}" in
            quick|full|discovery) ;;
            *) printf "sable-mode: invalid tier '%s' (must be quick, full, or discovery)\n" "$tier" >&2; exit 2 ;;
        esac

        since="$(date +%Y-%m-%dT%H:%M:%S%z)"
        mkdir -p "$(dirname "$STATE")"
        STATE="$STATE" MODE="$mode" SINCE="$since" FLEET="$fleet_csv" TIER="${tier:-full}" python3 -c "
import json, os
fleet = [s for s in os.environ.get('FLEET', '').split(',') if s]
mode = os.environ['MODE']
data = {'mode': mode, 'since': os.environ['SINCE'], 'fleet': fleet}
# Planning is a staged sub-state machine; entering it starts at framing.
# Execution has no substage. The tier (quick|full|discovery, default full)
# telescopes the substage gate: quick-tier planning lets the interlock allow
# backlog authoring under the single /sable-plan approval instead of walking all
# five substages; discovery (Mode 1) likewise bypasses the backlog gate (it
# authors no implementation beads).
if mode == 'planning':
    data['substage'] = 'framing'
    data['tier'] = os.environ.get('TIER') or 'full'
with open(os.environ['STATE'], 'w') as f:
    f.write(json.dumps(data, indent=2) + chr(10))
"
        ensure_state_gitignored "$STATE"
        ;;
    substage)
        # Planning sub-state machine. Ordered:
        #   framing -> research -> architecture -> test-strategy -> decomposition
        # Only meaningful while mode == planning.
        require_state
        action="${2:-}"
        substages="framing research architecture test-strategy decomposition"
        case "$action" in
            get)
                STATE="$STATE" python3 -c "
import json, os
d = json.load(open(os.environ['STATE']))
if d.get('mode') != 'planning':
    raise SystemExit(1)
s = d.get('substage') or ''
if not s:
    raise SystemExit(1)
print(s)
"
                ;;
            set)
                name="${3:-}"
                case " $substages " in
                    *" $name "*) ;;
                    *)
                        printf "sable-mode: invalid substage '%s' (must be one of: %s)\n" "$name" "$substages" >&2
                        exit 2
                        ;;
                esac
                STATE="$STATE" NAME="$name" python3 -c "
import json, os
d = json.load(open(os.environ['STATE']))
if d.get('mode') != 'planning':
    raise SystemExit(1)
d['substage'] = os.environ['NAME']
with open(os.environ['STATE'], 'w') as f:
    f.write(json.dumps(d, indent=2) + chr(10))
"
                ;;
            advance)
                STATE="$STATE" SUBSTAGES="$substages" python3 -c "
import json, os
order = os.environ['SUBSTAGES'].split()
d = json.load(open(os.environ['STATE']))
if d.get('mode') != 'planning':
    raise SystemExit(1)
cur = d.get('substage')
if cur not in order:
    raise SystemExit(1)
i = order.index(cur)
if i + 1 >= len(order):
    raise SystemExit(1)   # already at decomposition — cannot advance further
d['substage'] = order[i + 1]
with open(os.environ['STATE'], 'w') as f:
    f.write(json.dumps(d, indent=2) + chr(10))
"
                ;;
            *)
                printf 'sable-mode: substage requires: get | set <name> | advance\n' >&2
                exit 1
                ;;
        esac
        ;;
    tier)
        # Planning tier (quick|full). Read by the interlock to telescope the
        # backlog gate. Defaults to full when in planning mode and unset.
        require_state
        action="${2:-}"
        case "$action" in
            get)
                STATE="$STATE" python3 -c "
import json, os
d = json.load(open(os.environ['STATE']))
if d.get('mode') != 'planning':
    raise SystemExit(1)
print(d.get('tier') or 'full')
"
                ;;
            *)
                printf 'sable-mode: tier requires: get\n' >&2
                exit 1
                ;;
        esac
        ;;
    ""|*)
        usage
        exit 1
        ;;
esac
