#!/usr/bin/env python3
# DEPRECATED (SABLE-uz9.7): sable-status is no longer the default surface for the v2
# one-window topology. The Lincoln main session + named subagents pattern does not require
# a separate dashboard pane. This binary is kept because the dashboard may return as an
# optional pane in a future iteration — do not delete. The Zellij/sable-status surface has
# been superseded by the one-window topology documented in COCKPIT-DESIGN.md.
"""sable-status — read-only cockpit dashboard for the second Zellij pane.

Polls the cockpit mode-state, the bead pool, and the live agent processes, and
renders a per-mode status frame. Pure render functions (render/render_planning/
render_execution) take a normalized snapshot and return text — testable from
fixtures. gather_snapshot() is the only IO; SABLE_STATUS_FIXTURE injects every
source (incl. per-pid /proc identity, active-bead markers, in-progress beads) so
tests never touch the real /proc, bd, or claude.

Execution view (north star): each live claude process is enriched with its SABLE
identity from /proc/<pid>/environ (CLAUDE_AGENT_NAME), cross-referenced to the
bead it is working via a per-agent active marker, and shown with status + repo +
uptime. Processes with no SABLE identity (plain sessions, incl. the dashboard's
own observer) are counted, not listed. Work-in-progress comes from bd, not the
process list — the process list only gives liveness.

Usage:
  sable-status            # live Textual dashboard
  sable-status --once     # one frame to stdout, then exit (scriptable/tests)
  sable-status --help

Env:
  SABLE_MODE_STATE     mode-state path (default ~/.claude/sable/state/mode-state.json)
  SABLE_STATUS_FIXTURE    JSON fixture; when set, bd/claude//proc are not consulted
  SABLE_STATUS_INTERVAL   live refresh seconds (default 2.0)
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

FINDING_LABELS = {"sherlock": "sherlock-finding", "columbo": "columbo-test-spec", "gaudi": "gaudi-arch-gap"}
MERGE_LABEL = "for-chuck"
INBOX_LABEL = "for-cockpit"


# ---------------------------------------------------------------- IO layer

def _run_json(cmd: list[str], env: dict) -> Any:
    try:
        out = subprocess.run(cmd, capture_output=True, text=True, env=env, timeout=5)
        txt = out.stdout.strip()
        return json.loads(txt) if txt else []
    except Exception:
        return []


def _label_count(label: str, env: dict) -> int:
    data = _run_json(["bd", "list", "-l", label, "--json"], env)
    return len(data) if isinstance(data, list) else 0


def _read_proc_identity(pid: Any) -> dict:
    """Map a live process to its SABLE identity via /proc/<pid>/environ."""
    try:
        with open(f"/proc/{int(pid)}/environ", "rb") as f:
            raw = f.read().decode("utf-8", "replace")
        env = dict(kv.split("=", 1) for kv in raw.split("\x00") if "=" in kv)
        return {"name": env.get("CLAUDE_AGENT_NAME"), "role": env.get("CLAUDE_AGENT_ROLE")}
    except Exception:
        return {}


def _read_active_markers(env: dict) -> dict:
    """Per-agent active-bead markers: ~/.claude/sable/state/active/<name>.json."""
    home = env.get("HOME") or str(Path.home())
    d = Path(home) / ".claude" / "sable" / "state" / "active"
    out: dict = {}
    try:
        for f in d.glob("*.json"):
            try:
                out[f.stem] = json.loads(f.read_text())
            except Exception:
                pass
    except Exception:
        pass
    return out


def _read_mode_state(env: dict) -> dict:
    path = env.get("SABLE_MODE_STATE") or str(Path.home() / ".claude" / "sable" / "state" / "mode-state.json")
    try:
        with open(path) as fh:
            d = json.load(fh)
        return {"mode": d.get("mode"), "since": d.get("since", ""), "fleet": d.get("fleet", []) or []}
    except Exception:
        return {"mode": None, "since": "", "fleet": []}


def gather_snapshot(env: dict | None = None) -> dict:
    """The only IO. Returns a normalized snapshot the render functions consume."""
    env = dict(os.environ if env is None else env)
    mode_state = _read_mode_state(env)

    fixture = env.get("SABLE_STATUS_FIXTURE")
    if fixture and os.path.exists(fixture):
        with open(fixture) as fh:
            raw = json.load(fh)
        raw.setdefault("now", time.time())
    else:
        procs = _run_json(["claude", "agents", "--json"], env)
        if not isinstance(procs, list):
            procs = []
        labels = list(FINDING_LABELS.values()) + [MERGE_LABEL, INBOX_LABEL]
        raw = {
            "ready": _run_json(["bd", "ready", "--json"], env),
            "blocked": _run_json(["bd", "blocked", "--json"], env),
            "counts": {lbl: _label_count(lbl, env) for lbl in labels},
            "agents": procs,
            "proc_identity": {str(p.get("pid")): _read_proc_identity(p.get("pid")) for p in procs if p.get("pid")},
            "active": _read_active_markers(env),
            "in_progress": _run_json(["bd", "list", "--status=in_progress", "--json"], env),
            "now": time.time(),
        }
    return _normalize(raw, mode_state)


def _fmt_uptime(seconds: float) -> str:
    s = int(seconds)
    if s < 0:
        return ""
    if s < 60:
        return f"{s}s"
    m = s // 60
    if m < 60:
        return f"{m}m"
    h, m = divmod(m, 60)
    return f"{h}h{m}m" if m else f"{h}h"


def _normalize_agent(p: dict, ident: dict, active: dict, now: float) -> dict:
    name = ident.get("name")
    started = p.get("startedAt")
    uptime = _fmt_uptime(now - started / 1000) if started else ""
    repo = os.path.basename((p.get("cwd") or "").rstrip("/")) or "?"
    bead = (active.get(name) or {}).get("bead") if name else None
    return {
        "name": name, "role": ident.get("role"), "status": p.get("status", "?"),
        "repo": repo, "uptime": uptime, "bead": bead, "is_sable": name is not None,
    }


def _normalize(raw: dict, ms: dict) -> dict:
    counts = raw.get("counts", {}) or {}
    procs = raw.get("agents", []) or []
    proc_identity = raw.get("proc_identity", {}) or {}
    active = raw.get("active", {}) or {}
    now = raw.get("now") or time.time()
    agents = [_normalize_agent(p, proc_identity.get(str(p.get("pid")), {}) or {}, active, now) for p in procs]
    wip = [{"id": w.get("id"), "title": w.get("title", "") or "", "parent": w.get("parent")}
           for w in (raw.get("in_progress", []) or [])]
    return {
        "mode": ms["mode"], "since": ms["since"], "fleet": ms["fleet"],
        "pool": {"ready": len(raw.get("ready", []) or []), "blocked": len(raw.get("blocked", []) or [])},
        "findings": {key: int(counts.get(lbl, 0) or 0) for key, lbl in FINDING_LABELS.items()},
        "merge_queue": int(counts.get(MERGE_LABEL, 0) or 0),
        "inbox": int(counts.get(INBOX_LABEL, 0) or 0),
        "agents": agents, "wip": wip,
    }


# ---------------------------------------------------------------- render layer (pure)

def render_planning(s: dict) -> str:
    pool, f = s["pool"], s["findings"]
    victor = "in fleet" if "victor" in s.get("fleet", []) else "idle"
    return "\n".join([
        "SABLE cockpit",
        f"MODE  ▣ PLANNING   since {s['since']}",
        f"pool  {pool['ready']} ready · {pool['blocked']} blocked",
        "producers",
        f"  sherlock  {f['sherlock']} findings",
        f"  columbo   {f['columbo']} specs",
        f"  gaudi     {f['gaudi']} arch-gaps",
        f"  victor    {victor}",
    ])


def _wip_lines(s: dict) -> list[str]:
    lines = ["in progress"]
    if not s["wip"]:
        lines.append("  (nothing in progress)")
        return lines
    for w in s["wip"]:
        title = (w["title"][:34] + "…") if len(w["title"]) > 35 else w["title"]
        parent = f"  (↳ {w['parent']})" if w.get("parent") else ""
        lines.append(f"  {str(w['id']):<13} {title}{parent}")
    return lines


def render_execution(s: dict) -> str:
    pool = s["pool"]
    lines = [
        "SABLE cockpit",
        f"MODE  ▶ EXECUTION   since {s['since']}",
        f"pool  {pool['ready']} ready   merge-queue {s['merge_queue']}   inbox {s['inbox']}",
        "fleet",
    ]
    fleet = [a for a in s["agents"] if a["is_sable"]]
    others = [a for a in s["agents"] if not a["is_sable"]]
    if not fleet:
        lines.append("  (no SABLE agents running)")
    else:
        for a in fleet:
            bead = ("▶ " + a["bead"]) if a["bead"] else "—"
            lines.append(f"  {a['name']:<9} {a['status']:<6} {bead:<14} {a['repo']:<14} {a['uptime']}")
    if others:
        lines.append(f"  +{len(others)} other session{'s' if len(others) != 1 else ''}")
    lines += _wip_lines(s)
    return "\n".join(lines)


def render(s: dict) -> str:
    mode = s.get("mode")
    if mode == "planning":
        return render_planning(s)
    if mode == "execution":
        return render_execution(s)
    return "\n".join([
        "SABLE cockpit",
        "MODE  · (no mode set)",
        "Run /plan or /execute in the cockpit to choose a mode.",
    ])


# ---------------------------------------------------------------- live app

def run_app(interval: float = 2.0) -> int:
    from textual.app import App, ComposeResult
    from textual.widgets import Static

    class StatusApp(App):
        TITLE = "sable-status"

        def compose(self) -> ComposeResult:
            yield Static(id="frame")

        def on_mount(self) -> None:
            self._refresh()
            self.set_interval(interval, self._refresh)

        def _refresh(self) -> None:
            self.query_one("#frame", Static).update(render(gather_snapshot()))

    StatusApp().run()
    return 0


def main(argv: list[str] | None = None) -> int:
    argv = sys.argv[1:] if argv is None else argv
    if "-h" in argv or "--help" in argv:
        print(__doc__)
        return 0
    if "--once" in argv:
        print(render(gather_snapshot()))
        return 0
    interval = float(os.environ.get("SABLE_STATUS_INTERVAL", "2.0"))
    return run_app(interval)


if __name__ == "__main__":
    sys.exit(main())
