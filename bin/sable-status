#!/usr/bin/env python3
"""sable-status — read-only cockpit dashboard for the second Zellij pane.

Polls three sources on a short interval and renders a per-mode status frame:
  - the cockpit mode-state file (bin/sable-mode's schema)
  - the bead pool (`bd ready` / `bd list -l <label>` JSON)
  - live agent sessions (`claude agents --json`)

Architecture: pure render functions (render / render_planning / render_execution)
take a normalized snapshot and return text — deterministically testable from
fixtures. gather_snapshot() is the only IO; it honors a single injection point,
SABLE_STATUS_FIXTURE (a JSON file with keys ready/blocked/counts/agents), so
tests stay hermetic while production shells out to bd/claude. The Textual app is
a thin loop over render(gather_snapshot()).

Usage:
  sable-status            # launch the live Textual dashboard (pane 2)
  sable-status --once     # gather one snapshot, print the frame, exit (scriptable)
  sable-status --help

Env:
  SABLE_COCKPIT_STATE     mode-state path (default ~/.claude/sable/state/cockpit-mode.json)
  SABLE_STATUS_FIXTURE    JSON fixture file; when set, bd/claude are not shelled
  SABLE_STATUS_INTERVAL   live refresh seconds (default 2.0)
"""

from __future__ import annotations

import json
import os
import subprocess
import sys
from pathlib import Path
from typing import Any

# Label → snapshot mapping. The bd JSON projection does not include labels, so
# producer/queue counts come from label-filtered `bd list -l <label>` calls.
FINDING_LABELS = {
    "sherlock": "sherlock-finding",
    "columbo": "columbo-test-spec",
    "gaudi": "gaudi-arch-gap",
}
MERGE_LABEL = "for-chuck"
INBOX_LABEL = "for-cockpit"


# ---------------------------------------------------------------- IO layer

def _run_json(cmd: list[str], env: dict) -> Any:
    try:
        out = subprocess.run(cmd, capture_output=True, text=True, env=env, timeout=5)
        txt = out.stdout.strip()
        return json.loads(txt) if txt else []
    except Exception:
        return []


def _label_count(label: str, env: dict) -> int:
    data = _run_json(["bd", "list", "-l", label, "--json"], env)
    return len(data) if isinstance(data, list) else 0


def _read_mode_state(env: dict) -> dict:
    path = env.get("SABLE_COCKPIT_STATE") or str(
        Path.home() / ".claude" / "sable" / "state" / "cockpit-mode.json")
    try:
        with open(path) as fh:
            d = json.load(fh)
        return {"mode": d.get("mode"), "since": d.get("since", ""), "fleet": d.get("fleet", []) or []}
    except Exception:
        return {"mode": None, "since": "", "fleet": []}


def gather_snapshot(env: dict | None = None) -> dict:
    """The only IO. Returns a normalized snapshot the render functions consume."""
    env = dict(os.environ if env is None else env)
    mode_state = _read_mode_state(env)

    fixture = env.get("SABLE_STATUS_FIXTURE")
    if fixture and os.path.exists(fixture):
        with open(fixture) as fh:
            data = json.load(fh)
    else:
        labels = list(FINDING_LABELS.values()) + [MERGE_LABEL, INBOX_LABEL]
        # `blocked` is a derived state in bd (open with active blockers), not a
        # literal status value — use `bd blocked`, not `bd list --status=blocked`.
        data = {
            "ready": _run_json(["bd", "ready", "--json"], env),
            "blocked": _run_json(["bd", "blocked", "--json"], env),
            "counts": {lbl: _label_count(lbl, env) for lbl in labels},
            "agents": _run_json(["claude", "agents", "--json"], env),
        }
    return _normalize(data, mode_state)


def _normalize_agent(a: dict) -> dict:
    return {
        "name": a.get("name") or a.get("agent") or a.get("id") or "?",
        "state": a.get("state") or a.get("status") or "?",
        "bead": a.get("bead") or a.get("current_bead") or "",
        "workers": int(a.get("workers", 0) or 0),
    }


def _normalize(data: dict, ms: dict) -> dict:
    counts = data.get("counts", {}) or {}
    return {
        "mode": ms["mode"],
        "since": ms["since"],
        "fleet": ms["fleet"],
        "pool": {
            "ready": len(data.get("ready", []) or []),
            "blocked": len(data.get("blocked", []) or []),
        },
        "findings": {key: int(counts.get(lbl, 0) or 0) for key, lbl in FINDING_LABELS.items()},
        "merge_queue": int(counts.get(MERGE_LABEL, 0) or 0),
        "inbox": int(counts.get(INBOX_LABEL, 0) or 0),
        "agents": [_normalize_agent(a) for a in (data.get("agents", []) or [])],
    }


# ---------------------------------------------------------------- render layer (pure)

def render_planning(s: dict) -> str:
    pool, f = s["pool"], s["findings"]
    victor = "in fleet" if "victor" in s.get("fleet", []) else "idle"
    return "\n".join([
        "SABLE cockpit",
        f"MODE  ▣ PLANNING   since {s['since']}",
        f"pool  {pool['ready']} ready · {pool['blocked']} blocked",
        "producers",
        f"  sherlock  {f['sherlock']} findings",
        f"  columbo   {f['columbo']} specs",
        f"  gaudi     {f['gaudi']} arch-gaps",
        f"  victor    {victor}",
    ])


def render_execution(s: dict) -> str:
    pool = s["pool"]
    lines = [
        "SABLE cockpit",
        f"MODE  ▶ EXECUTION   since {s['since']}",
        f"pool  {pool['ready']} ready   merge-queue {s['merge_queue']}   inbox {s['inbox']}",
        "agents",
    ]
    if not s["agents"]:
        lines.append("  (no managers running)")
    else:
        for a in s["agents"]:
            bead = a["bead"] or "-"
            lines.append(f"  {a['name']:<8} {a['state']:<8} {bead:<12} {a['workers']}w")
    return "\n".join(lines)


def render(s: dict) -> str:
    mode = s.get("mode")
    if mode == "planning":
        return render_planning(s)
    if mode == "execution":
        return render_execution(s)
    return "\n".join([
        "SABLE cockpit",
        "MODE  · (no mode set)",
        "Run /plan or /execute in the cockpit to choose a mode.",
    ])


# ---------------------------------------------------------------- live app

def run_app(interval: float = 2.0) -> int:
    from textual.app import App, ComposeResult
    from textual.widgets import Static

    class StatusApp(App):
        TITLE = "sable-status"

        def compose(self) -> ComposeResult:
            yield Static(id="frame")

        def on_mount(self) -> None:
            self._refresh()
            self.set_interval(interval, self._refresh)

        def _refresh(self) -> None:
            self.query_one("#frame", Static).update(render(gather_snapshot()))

    StatusApp().run()
    return 0


def main(argv: list[str] | None = None) -> int:
    argv = sys.argv[1:] if argv is None else argv
    if "-h" in argv or "--help" in argv:
        print(__doc__)
        return 0
    if "--once" in argv:
        print(render(gather_snapshot()))
        return 0
    interval = float(os.environ.get("SABLE_STATUS_INTERVAL", "2.0"))
    return run_app(interval)


if __name__ == "__main__":
    sys.exit(main())
