# Personal feedback notes captured by sable-note — never committed.
# These are raw observations; curate via /sable-review into clean PRs when ready.
# Curated archives in feedback/processed/ are also personal — they retain
# verbatim observations and project-specific bead IDs that don't belong in
# the shared methodology repo.
feedback/*.md
feedback/processed/

# Backups created by install.sh / install.ps1 when prepending Prime Directives
*.bak.*

# Editor noise
.DS_Store
*.swp

# Python bytecode caches
__pycache__/
*.pyc

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# pytest-testmon coverage map (SABLE-cmar4.3) — CI-cached artifact, local
# scratch; -shm/-wal are SQLite WAL-mode sidecar files testmon leaves behind
.testmondata
.testmondata-shm
.testmondata-wal

# Cockpit install artifacts (project-scoped sable-orchestration-install output —
# installed copies of repo sources under skills/, templates/, hooks/; not source)
.claude/settings.local.json
.claude/skills/plan/
.claude/skills/execute/
.claude/sable/
.claude/hooks/multi-manager/mode-interlock.sh

# ONE exception inside .claude/sable/ (SABLE-jd5fj.5): the merge-gate state
# DIRECTORY and its README are tracked, so the freeze/quarantine location is
# real and documented in a fresh checkout; the state FILES inside it stay
# ephemeral and ignored (a freeze is a fact about a moment, not about a commit).
# The re-ignore lines are load-bearing: git will not descend into an excluded
# directory, so each level has to be un-excluded and then its OTHER contents
# re-excluded — that is what keeps mode-state.json and the installed cockpit
# artifacts ignored. hooks/test/test-snapshot-freeze.sh asserts both directions.
!.claude/sable/
.claude/sable/*
!.claude/sable/state/
.claude/sable/state/*
!.claude/sable/state/merge-gate/
.claude/sable/state/merge-gate/*
!.claude/sable/state/merge-gate/README.md
